<p>Dear {{ name }},</p>

<p>The job you applied for <strong>{{ job_title }}</strong> has been updated.</p>

{% if changes %}
  <p><strong>Updated fields:</strong></p>

  <table style="border-collapse: collapse; width: 100%; font-size: 14px;">
    <tr>
      <th style="border:1px solid #ddd; padding:8px;">Field</th>
      <th style="border:1px solid #ddd; padding:8px;">Old Value</th>
      <th style="border:1px solid #ddd; padding:8px;">New Value</th>
    </tr>

    {% for change in changes %}
      <tr>
        <td style="border:1px solid #ddd; padding:8px;">{{ change.label }}</td>
        <td style="border:1px solid #ddd; padding:8px;">{{ change.old }}</td>
        <td style="border:1px solid #ddd; padding:8px;">{{ change.new }}</td>
      </tr>
    {% endfor %}
  </table>
{% endif %}

<p>If you want to update your application or resume, please do so within the next <strong>2 hours</strong>.</p>

<p>Thank you,<br>HR Team</p>
