function jobs_module_views_pre_render(\Drupal\views\ViewExecutable $view)
{
  if ($view->id() === 'jobs_listing' && $view->current_display === 'page_1') {
    foreach ($view->result as $index => $row) {
      if (!empty($row->nid)) {
        $nid = $row->nid;
        $count = \Drupal::database()
          ->select('job_application', 'ja')
          ->condition('job_id', $nid)
          ->countQuery()
          ->execute()
          ->fetchField();

        $view->result[$index]->applicant_button =
          "<a href='/job/$nid/applicants' class='btn btn-primary'>Applicants ($count)</a>";
        $view->result[$index]->applicant_count = $count;
      }
    }
  }
}

function jobs_module_entity_update(Drupal\Core\Entity\EntityInterface $entity)
{
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'jobs') {
    return;
  }

  /** @var \Drupal\node\Entity\Node $node */
  $node = $entity;
  $original = $node->original;

  if (!$original) {
    return;
  }

  $changed_fields = [];
  $track_fields = [
    'title',
    'body',
    'field_job_department',
    'field_job_type',
    'field_job_status',
    'field_salary',
    'field_job_location',
    'field_requirements',
    'field_yes_no',
  ];

  foreach ($track_fields as $field) {
    if (!$node->hasField($field)) {
      continue;
    }

    $old_value = jobs_module_format_field($original, $field);
    $new_value = jobs_module_format_field($node, $field);

    if ($old_value !== $new_value) {
      $changed_fields[$field] = [
        'label' => $node->getFieldDefinition($field)->getLabel(),
        'old' => $old_value,
        'new' => $new_value,
      ];
    }
  }

  // If nothing changed → nothing to send.
  if (empty($changed_fields)) {
    return;
  }

  _jobs_module_notify_applicants($node, $changed_fields);
}

/**
 * Send email notifications to all applicants of a job.
 */
function _jobs_module_notify_applicants(\Drupal\node\Entity\Node $node, array $changed_fields)
{
  $records = \Drupal::database()->select('job_application', 'ja')
    ->fields('ja', ['applicant_name', 'applicant_email', 'public_user_id'])
    ->condition('job_id', $node->id())
    ->execute()
    ->fetchAllAssoc('public_user_id');

  if (!$records) return;

  $job_title = $node->getTitle();

  foreach ($records as $applicant) {

    $vars = [
      'name' => $applicant->applicant_name,
      'job_title' => $job_title,
      'changes' => array_values($changed_fields),  // FIXED: send ARRAY not HTML string
    ];

    $body = \Drupal::service('twig')->render(
      'modules/custom/jobs_module/templates/job_updated_mail.html.twig',
      $vars
    );

    jobs_module_send_mail('job_update_notification', $applicant->applicant_email, [
      'subject' => "Update on Job Position: $job_title",
      'body' => $body,
    ]);
  }
}


/**
 * Format a field value for email comparison.
 */
function jobs_module_format_field(\Drupal\node\Entity\Node $node, string $field)
{
  if (!$node->hasField($field) || $node->get($field)->isEmpty()) {
    return '';
  }

  $item = $node->get($field);
  $type = $item->getFieldDefinition()->getType();

  switch ($type) {

    case 'text_with_summary':
    case 'text_long':
      return mb_strimwidth(trim(strip_tags($item->value)), 0, 120, '...');

    case 'entity_reference':
      $term = $item->entity;
      return $term ? $term->label() : '';

    case 'boolean':
      return $item->value ? 'Yes' : 'No';

    case 'list_string':
      $allowed = $item->getFieldDefinition()->getSetting('allowed_values');
      return $allowed[$item->value] ?? $item->value;

    default:
      return trim($item->getString());
  }
}


/**
 * Notify applicants when a job node is deleted.
 */
/**
 * Implements hook_entity_predelete().
 *
 * Fires BEFORE a job node is deleted.
 */
function jobs_module_entity_predelete(\Drupal\Core\Entity\EntityInterface $entity)
{
  // Only act on job nodes.
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'jobs') {
    return;
  }

  /** @var \Drupal\node\Entity\Node $node */
  $node = $entity;

  // Fetch all applicants for this job.
  $records = \Drupal::database()->select('job_application', 'ja')
    ->fields('ja', ['applicant_name', 'applicant_email'])
    ->condition('job_id', $node->id())
    ->execute()
    ->fetchAll();

  if (!$records) {
    return;
  }

  $job_title = $node->getTitle();

  // Send "job closed" email to each applicant.
  foreach ($records as $applicant) {

    $vars = [
      'name' => $applicant->applicant_name,
      'job_title' => $job_title,
    ];

    $body = \Drupal::service('twig')->render(
      'modules/custom/jobs_module/templates/job_deleted_mail.html.twig',
      $vars
    );

    jobs_module_send_mail('job_deleted_notification', $applicant->applicant_email, [
      'subject' => "Hiring Closed – $job_title",
      'body' => $body,
    ]);
  }
}
