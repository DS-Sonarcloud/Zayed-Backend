<?php

use Drupal\views\ViewExecutable;
use Drupal\webform\WebformSubmissionInterface;
use Drupal\views\Plugin\views\join\Standard;

/**
 * Implements hook_mail().
 */
function jobs_module_mail($key, &$message, $params)
{
  switch ($key) {
    case 'application_received_applicant':
    case 'application_received_admin':
    case 'application_status_update':
    case 'application_updated_user':
    case 'application_updated_admin':
    case 'job_update_notification':
    case 'job_deleted_notification':

      $message['subject'] = $params['subject'] ?? '(No subject)';
      $message['body'][] = $params['body'] ?? '(No body)';
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

      break;
  }
}
function jobs_module_page_attachments(array &$attachments) {
  $current_route = \Drupal::routeMatch()->getRouteName();

  // Load CSS only on your job pages
  if (str_starts_with($current_route, 'jobs_module.')) {
    $attachments['#attached']['library'][] = 'jobs_module/job_styles';
  }
}


/**
 * Helper: send mail via mail manager.
 */
function jobs_module_send_mail($key, $to, array $params = [])
{
  $mailManager = \Drupal::service('plugin.manager.mail');
  $module = 'jobs_module';
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();
  return $mailManager->mail($module, $key, $to, $langcode, $params);
}


