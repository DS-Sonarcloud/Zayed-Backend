<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_entity_insert().
 */
function campaign_email_queue_entity_insert(EntityInterface $entity)
{
  if ($entity instanceof NodeInterface && $entity->bundle() === 'campaign') {
    \Drupal::service('campaign_email_queue.queue')->initializeQueueForCampaign($entity);
    
    // Ensure the email template stays published after campaign creation
    if ($entity->hasField('field_email_template') && !$entity->get('field_email_template')->isEmpty()) {
      $template_id = $entity->get('field_email_template')->target_id;
      if ($template_id) {
        $template = \Drupal\node\Entity\Node::load($template_id);
        if ($template && $template->hasField('moderation_state')) {
          $current_state = $template->get('moderation_state')->value;
          
          // If template was set to needs_review due to screenshot update, restore to published
          if ($current_state === 'needs_review') {
            
            $template->set('moderation_state', 'published');
            $template->setPublished(TRUE);
            $template->save();
          }
        }
      }
    }
  }
}

/**
 * Implements hook_entity_delete().
 */
function campaign_email_queue_entity_delete(EntityInterface $entity)
{
  if ($entity instanceof NodeInterface && $entity->bundle() === 'campaign') {
    \Drupal::service('campaign_email_queue.queue')->deleteQueueForCampaign($entity->id());

    if ($entity->hasField('field_email_template') && !$entity->get('field_email_template')->isEmpty()) {
      $template_id = $entity->get('field_email_template')->target_id;
      if ($template_id) {
        $template = \Drupal\node\Entity\Node::load($template_id);
        if ($template) {
          $campaign_refs = $template->get('field_campaign')->getValue();
          $new_refs = [];
          foreach ($campaign_refs as $ref) {
            if ($ref['target_id'] != $entity->id()) {
              $new_refs[] = $ref;
            }
          }
          if (count($new_refs) < count($campaign_refs)) {
            $template->set('field_campaign', $new_refs);
            $template->save();
          }
        }
      }
    }
  }
}

/**
 * Implements hook_mail().
 */
function campaign_email_queue_mail($key, &$message, $params)
{
  if ($key === 'campaign_message') {
    $message['subject'] = $params['subject'];
    $message['body'][] = $params['body'];
    $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed';

    \Drupal::logger('campaign_email_queue')->debug('Sending campaign email to: @to', [
      '@to' => $message['to'],
    ]);
  }
}

/**
 * Implements hook_page_attachments().
 *
 * Keeps campaign sending alive while any admin page is open (no Drush).
 */
function campaign_email_queue_page_attachments(array &$attachments): void {
  $account = \Drupal::currentUser();
  if ($account->isAnonymous() || !$account->hasPermission('access campaign email queue dashboard')) {
    return;
  }

  /** @var \Drupal\campaign_email_queue\Service\CampaignProcessingState $state */
  $state = \Drupal::service('campaign_email_queue.processing_state');
  if ($state->getActiveCampaignIds() === []) {
    return;
  }

  $queue_service = \Drupal::service('campaign_email_queue.queue');
  $settings = $queue_service->getSettings();

  $attachments['#attached']['library'][] = 'campaign_email_queue/admin_keepalive';
  $attachments['#attached']['drupalSettings']['campaignEmailQueueKeepalive'] = [
    'url' => \Drupal\Core\Url::fromRoute('campaign_email_queue.keepalive')->toString(),
    'intervalMs' => $settings['admin_keepalive_interval_ms'],
  ];
}

/**
 * Implements hook_form_BASE_FORM_ID_alter().
 */
function campaign_email_queue_form_node_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id)
{
  $node = $form_state->getFormObject()->getEntity();

  if ($node->bundle() === 'campaign') {
    $form['#attached']['library'][] = 'campaign_email_queue/campaign_admin';

    $query = \Drupal::entityQuery('node')
      ->condition('type', 'email_template')
      ->condition('status', 1)
      ->accessCheck(FALSE);

    $or_group = $query->orConditionGroup()
      ->notExists('field_campaign');

    if (!$node->isNew()) {
      $or_group->condition('field_campaign', $node->id());
    }

    $query->condition($or_group);

    // Apply department filtering to availability check.
    /** @var \Drupal\campaign_email_queue\Service\CampaignEmailQueueService $queue_service */
    $queue_service = \Drupal::service('campaign_email_queue.queue');
    $account = \Drupal::currentUser();
    $queue_service->applyCampaignAccess($query, $account);

    $count = $query->count()->execute();

    if ($count == 0) {
      $msg = t('No available Email Templates found. Please <a href=":url">create an Email Template</a> first.', [
        ':url' => \Drupal\Core\Url::fromRoute('node.add', ['node_type' => 'email_template'])->toString(),
      ]);

      if (isset($form['field_email_template']['widget']['#description'])) {
        $form['field_email_template']['widget']['#description'] .= '<br/><strong>' . $msg . '</strong>';
      } elseif (isset($form['field_email_template']['widget'][0]['target_id']['#description'])) {
        $form['field_email_template']['widget'][0]['target_id']['#description'] .= '<br/><strong>' . $msg . '</strong>';
      } else {
        $form['field_email_template']['#prefix'] = '<div class="messages messages--warning">' . $msg . '</div>';
      }
    }
  }

  if ($node->bundle() === 'email_template') {
    if (!$node->isNew()) {
      $query = \Drupal::entityQuery('node')
        ->condition('type', 'campaign')
        ->condition('field_email_template', $node->id())
        ->accessCheck(FALSE);

      // Only lock if the campaign is visible to the user.
      $account = \Drupal::currentUser();
      /** @var \Drupal\campaign_email_queue\Service\CampaignEmailQueueService $queue_service */
      $queue_service = \Drupal::service('campaign_email_queue.queue');
      $queue_service->applyCampaignAccess($query, $account);

      $result = $query->execute();

      if (!empty($result)) {
        if (isset($form['status']['widget']['value'])) {
          $form['status']['widget']['value']['#disabled'] = TRUE;
          $form['status']['widget']['value']['#description'] = t('This Email Template is currently used by a campaign and cannot be unpublished.');
        } elseif (isset($form['status']['#type'])) {
          $form['status']['#disabled'] = TRUE;
          $form['status']['#description'] .= ' ' . t('This Email Template is currently used by a campaign and cannot be unpublished.');
        }

        // Handle content moderation state.
        if (isset($form['moderation_state']['widget'][0]['state'])) {
          $form['moderation_state']['widget'][0]['state']['#disabled'] = TRUE;
          $form['moderation_state']['widget'][0]['state']['#description'] = t('This Email Template is currently used by a campaign and cannot be unpublished.');
        }

        if (isset($form['actions']['delete'])) {
          $form['actions']['delete']['#attributes']['class'][] = 'is-disabled';
          $form['actions']['delete']['#attributes']['style'] = 'pointer-events: none; opacity: 0.5; cursor: not-allowed;';
          $form['actions']['delete']['#attributes']['onclick'] = 'return false;';
          $form['actions']['delete']['#disabled'] = TRUE;
        }

        // Disable save button
        if (isset($form['actions']['submit'])) {
          $form['actions']['submit']['#disabled'] = TRUE;
          $form['actions']['preview']['#disabled'] = TRUE;
          $form['actions']['submit']['#value'] = t('Cannot save - Template in use');
        }
      }
    }
  }
}

/**
 * Implements hook_cron().
 *
 * Drains background send workers. Only continues user-started or due scheduled
 * campaigns — never auto-starts legacy queues.
 */
function campaign_email_queue_cron(): void {
  $now_ts = \Drupal::time()->getRequestTime();
  $logger = \Drupal::logger('campaign_email_queue');

  /** @var \Drupal\campaign_email_queue\Service\CampaignEmailQueueService $queue_service */
  $queue_service = \Drupal::service('campaign_email_queue.queue');
  /** @var \Drupal\campaign_email_queue\Service\CampaignProcessingState $processing_state */
  $processing_state = \Drupal::service('campaign_email_queue.processing_state');
  /** @var \Drupal\campaign_email_queue\Service\CampaignEmailLogService $log_service */
  $log_service = \Drupal::service('campaign_email_queue.log');

  $settings = $queue_service->getSettings();
  $queue_service->drainBackgroundSendQueue($settings['cron_background_seconds']);

  $scheduled_started = \Drupal::state()->get('campaign_email_queue.scheduled_started', []);
  if (!is_array($scheduled_started)) {
    $scheduled_started = [];
  }

  $schedule_query = \Drupal::entityQuery('node')
    ->condition('type', 'campaign')
    ->condition('status', 1)
    ->exists('field_scheduled_time')
    ->accessCheck(FALSE);
  $scheduled_nids = $schedule_query->execute();

  if (!empty($scheduled_nids)) {
    $nodes = \Drupal::entityTypeManager()->getStorage('node')->loadMultiple($scheduled_nids);
    foreach ($nodes as $node) {
      $nid = (int) $node->id();
      if ($node->get('field_queue_paused')->value || $processing_state->isActive($nid)) {
        continue;
      }
      if (!empty($scheduled_started[$nid])) {
        continue;
      }
      $scheduled_val = $node->get('field_scheduled_time')->value;
      if (empty($scheduled_val)) {
        continue;
      }
      $scheduled_ts = (int) strtotime($scheduled_val . ' UTC');
      if ($scheduled_ts > $now_ts) {
        continue;
      }
      if ($queue_service->getQueueCount($nid) <= 0) {
        continue;
      }
      $logger->info('Auto-starting scheduled campaign @nid.', ['@nid' => $nid]);
      $processing_state->mark($nid);
      $queue_service->startBackgroundSending($nid);
      $scheduled_started[$nid] = $now_ts;
    }
  }
  \Drupal::state()->set('campaign_email_queue.scheduled_started', $scheduled_started);

  $active_ids = $processing_state->getActiveCampaignIds();
  if ($active_ids !== []) {
    $nids = \Drupal::entityQuery('node')
      ->condition('type', 'campaign')
      ->condition('status', 1)
      ->condition('nid', $active_ids, 'IN')
      ->accessCheck(FALSE)
      ->execute();
    if (!empty($nids)) {
      $nodes = \Drupal::entityTypeManager()->getStorage('node')->loadMultiple($nids);
      foreach ($nodes as $node) {
        $nid = (int) $node->id();
        if ($node->get('field_queue_paused')->value) {
          continue;
        }
        $queue_service->ensureBackgroundSending($nid);
        if ($queue_service->getQueueCount($nid) === 0) {
          $counts = $log_service->getLogStatusCounts($nid);
          if ($counts['pending'] === 0) {
            $processing_state->clear($nid);
          }
        }
      }
    }
  }
}

/**
 * Implements hook_preprocess_views_view_unformatted().
 */
function campaign_email_queue_preprocess_views_view_unformatted(&$variables)
{
  $view = $variables['view'];
  if ($view->id() === 'email_templates') {
    $variables['#cache']['max-age'] = 0;
    $log_service = \Drupal::service('campaign_email_queue.log');
    $date_formatter = \Drupal::service('date.formatter');

    $account = \Drupal::currentUser();
    $variables['can_manage_campaigns'] = $account->hasPermission('access campaign email queue dashboard');
    $variables['can_administer_user_groups'] = $account->hasPermission('administer user groups');
    $variables['can_manage_grapesjs_images'] = $account->hasPermission('grapesjs editor image manager');
    $variables['can_create_email_template'] = $account->hasPermission('create email_template content');

    foreach ($variables['rows'] as &$row) {
      /** @var \Drupal\node\NodeInterface $entity */
      $entity = $row['content']['#row']->_entity;

      if ($entity->hasField('field_campaign') && !$entity->get('field_campaign')->isEmpty()) {
        $campaign_node = $entity->get('field_campaign')->entity;
        if ($campaign_node) {
          $stats = $log_service->getCampaignStatistics($campaign_node->id());
          if ($stats && !empty($stats->last_updated)) {
            $row['last_run_time'] = $date_formatter->format($stats->last_updated, 'short');
          } else {
            $row['last_run_time'] = t('Never');
          }

          $real_time_status = $log_service->getRealTimeStatus($campaign_node->id());
          $row['status_label'] = ucfirst(str_replace('_', ' ', $real_time_status['status']));
          $row['status_machine_name'] = $real_time_status['status'];
          $row['campaign_type'] = $campaign_node->get('field_campaign_type')->value ?? t('Unknown');
        }
      } else {
        // Not associated with a campaign - show moderation state or publication status
        if ($entity->hasField('moderation_state') && !$entity->get('moderation_state')->isEmpty()) {
          $mod_state = $entity->get('moderation_state')->value;
          $row['status_label'] = ucfirst(str_replace('_', ' ', $mod_state));
          $row['status_machine_name'] = $mod_state;
        } else {
          $row['status_label'] = $entity->isPublished() ? t('Published') : t('Unpublished');
          $row['status_machine_name'] = $entity->isPublished() ? 'published' : 'unpublished';
        }
        $row['campaign_type'] = t('Not assigned');
        $row['last_run_time'] = t('Never');
      }
    }
  }
}

/**
 * Implements hook_entity_query_alter().
 */
function campaign_email_queue_entity_query_alter(\Drupal\Core\Entity\Query\QueryInterface $query)
{
  if ($query->hasTag('entity_reference')) {
    $handler = $query->getMetaData('entity_reference_selection_handler');
    if ($handler && $handler->getPluginId() == 'default:node') {
      $configuration = $handler->getConfiguration();

      if (isset($configuration['target_bundles']) && in_array('email_template', $configuration['target_bundles'])) {

        $route_match = \Drupal::routeMatch();
        $route_name = $route_match->getRouteName();
        $current_campaign_id = NULL;
        $is_campaign_form = FALSE;

        if ($route_name === 'entity.node.edit_form') {
          $node = $route_match->getParameter('node');
          if ($node instanceof \Drupal\node\NodeInterface && $node->bundle() === 'campaign') {
            $current_campaign_id = $node->id();
            $is_campaign_form = TRUE;
          }
        } elseif ($route_name === 'node.add') {
          $node_type = $route_match->getParameter('node_type');
          if ($node_type instanceof \Drupal\node\Entity\NodeType && $node_type->id() === 'campaign') {
            $current_campaign_id = NULL;
            $is_campaign_form = TRUE;
          }
        }

        if ($is_campaign_form) {
          $or_group = $query->orConditionGroup()
            ->notExists('field_campaign');
          if ($current_campaign_id) {
            $or_group->condition('field_campaign', $current_campaign_id);
          }
          $query->condition($or_group);
          $query->condition('status', 1);

          $account = \Drupal::currentUser();
          /** @var \Drupal\campaign_email_queue\Service\CampaignEmailQueueService $queue_service */
          $queue_service = \Drupal::service('campaign_email_queue.queue');
          $queue_service->applyCampaignAccess($query, $account);
        }
      }
    }
  }
}

/**
 * Implements hook_node_access().
 */
function campaign_email_queue_node_access(\Drupal\node\NodeInterface $node, $op, \Drupal\Core\Session\AccountInterface $account)
{
  if ($node->bundle() === 'email_template' && $op === 'delete') {
    $query = \Drupal::entityQuery('node')
      ->condition('type', 'campaign')
      ->condition('field_email_template', $node->id())
      ->accessCheck(FALSE);

    // Only lock delete if a campaign using it is accessible by the user.
    /** @var \Drupal\campaign_email_queue\Service\CampaignEmailQueueService $queue_service */
    $queue_service = \Drupal::service('campaign_email_queue.queue');
    $queue_service->applyCampaignAccess($query, $account);

    $result = $query->execute();

    if (!empty($result)) {
      return \Drupal\Core\Access\AccessResult::forbidden()->addCacheableDependency($node);
    }
  }
  return \Drupal\Core\Access\AccessResult::neutral();
}


/**
 * Implements hook_entity_update().
 */
function campaign_email_queue_entity_update(EntityInterface $entity) {
  if ($entity instanceof NodeInterface && $entity->bundle() === 'campaign') {
    // Check if email template field has changed.
    $original = $entity->original;
    if ($original instanceof NodeInterface) {
      $old_tid = $original->hasField('field_email_template') && !$original->get('field_email_template')->isEmpty()
        ? $original->get('field_email_template')->target_id
        : NULL;
      
      $new_tid = $entity->hasField('field_email_template') && !$entity->get('field_email_template')->isEmpty()
        ? $entity->get('field_email_template')->target_id
        : NULL;

      // If the template changed (or was removed), clean up the old one.
      if ($old_tid && $old_tid != $new_tid) {
        $old_template = \Drupal\node\Entity\Node::load($old_tid);
        if ($old_template) {
          $campaign_refs = $old_template->get('field_campaign')->getValue();
          $new_refs = [];
          foreach ($campaign_refs as $ref) {
            if ($ref['target_id'] != $entity->id()) {
              $new_refs[] = $ref;
            }
          }
          if (count($new_refs) < count($campaign_refs)) {
            $old_template->set('field_campaign', $new_refs);
            $old_template->save();
          }
        }
      }
    }
  }
}

/**
 * Implements hook_cloned_node_alter().
 */
function campaign_email_queue_cloned_node_alter(\Drupal\node\NodeInterface $node, \Drupal\node\NodeInterface $original_node)
{
  if ($node->bundle() === 'email_template') {
    if ($node->hasField('field_campaign')) {
      $node->set('field_campaign', []);
    }
    if ($node->hasField('field_template_image')) {
      $node->set('field_template_image', []);
    }
  }
}