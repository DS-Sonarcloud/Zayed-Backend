    //     'is_rtl' => null,
    //     'drupal_layoutbuilder_data' => null,
    //     'elementor_tmp' => null,
    //     'base_path' => \Drupal::request()->getBasePath()
    //   ],
    // ],

  ];
}

/**
 * Implements hook_theme_suggestions_alter().
 */
function drupal_layoutbuilder_theme_suggestions_alter(array &$suggestions, array $variables, $hook)
{
  if ($hook !== 'page' && $hook !== 'node') {
    return;
  }

  $node = \Drupal::routeMatch()->getParameter('node');
  $allow_content_types = _drupal_layoutbuilder_allowed_node_types();

  if ($node instanceof \Drupal\node\NodeInterface && in_array($node->getType(), $allow_content_types, true)) {
    // Check that instance and sdk are initialized
    if (
      !empty(DrupalLayoutbuilderPlugin::$instance) &&
      !empty(DrupalLayoutbuilderPlugin::$instance->sdk)
    ) {
      $config = DrupalLayoutbuilderPlugin::$instance->sdk->get_data($node->id());

      if ($hook == 'page' && isset($config['settings']['template']) && $config['settings']['template'] == 'elementor_canvas') {
        $suggestions[] = 'drupal_layoutbuilder_field';
      } elseif ($hook == 'page' && isset($config['settings']['template']) && $config['settings']['template'] == 'elementor_header_footer') {
        $suggestions[] = 'drupal_layoutbuilder_field';
      } elseif ($hook == 'node' && (!isset($config['settings']['template']) || empty($config['settings']['template']))) {
        $suggestions[] = 'drupal_layoutbuilder_field';
      }
    }
  }
}

/**
 * Implements hook_preprocess().
 */

function drupal_layoutbuilder_preprocess_node(&$variables)
{
  $node = \Drupal::routeMatch()->getParameter('node');
  $allow_content_types = _drupal_layoutbuilder_allowed_node_types();

  if ($node instanceof \Drupal\node\NodeInterface && in_array($node->getType(), $allow_content_types, true)) {
    $variables['#cache']['max-age'] = 0;
  }
}

/**
 * Implements hook_preprocess().
 */

function drupal_layoutbuilder_preprocess_drupal_layoutbuilder_field(&$variables)
{
  global $base_path;
  $node = \Drupal::routeMatch()->getParameter('node');
  $id = $node->id();
  $DrupalLayoutbuilderPlugin = DrupalLayoutbuilderPlugin::$instance;
  $frontend_data = $DrupalLayoutbuilderPlugin->frontend($id);
  $dir = \Drupal::languageManager()->getCurrentLanguage()->getDirection();
  $variables['is_rtl'] = $dir == 'rtl';
  $variables['base_path'] = $base_path . \Drupal::moduleHandler()->getModule('drupal_layoutbuilder')->getPath();
  $variables['drupal_layoutbuilder_tmp'] = $frontend_data;
  $variables['uid'] = $id;
  $variables['#cache']['max-age'] = 0;
}
/**
 * Implements hook__menu_local_tasks_alter().
 */

function drupal_layoutbuilder_menu_local_tasks_alter(&$data, $route_name)
{
  global $base_url;

  $allow_content_types = _drupal_layoutbuilder_allowed_node_types();
  $node = \Drupal::routeMatch()->getParameter('node');

  if ($node instanceof \Drupal\node\NodeInterface) {
    $nid = $node->id(); // Node object -> use id() method
  } elseif (is_numeric($node)) {
    $nid = $node; // Already a node ID
  } else {
    $nid = 1; // Default fallback
  }
  if ($route_name == 'entity.node.canonical' && $node instanceof \Drupal\node\NodeInterface && in_array($node->getType(), $allow_content_types, true)) {
    $data['tabs'][0]['entity.node.canonical'] = [
      '#theme' => 'menu_local_task',
      '#link' => [
        'title' => t('Drupal Layout Builder'),
        'url' => \Drupal\Core\Url::fromRoute('drupal_layoutbuilder.editor', ['node' => $nid]),
        'localized_options' => [
          'attributes' => [
            'title' => t('Open the visual layout editor'),
          ],
        ],
      ],
    ];
  }
}

/**
 * Implements hook_form_alter().
 */
function drupal_layoutbuilder_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof EntityFormInterface) {
    return;
  }
  $entity = $form_object->getEntity();
  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }
  $bundle = $entity->bundle();
  $allow_content_types = _drupal_layoutbuilder_allowed_node_types();
  if (!in_array($bundle, $allow_content_types, true)) {
    return;
  }

  $form['edit_with_drupal_layoutbuilder'] = [
    '#type' => 'submit',
    '#value' => t('Drupal Layout Builder'),
    '#attributes' => [
      'class' => ['eicon-layoutbuilder', 'edit-with-drupal-layoutbuilder'],
    ],
    '#submit' => ['drupal_layoutbuilder_edit_with_layoutbuilder_form_submit'],
  ];
  if (isset($form['body']['#weight'])) {
    $form['edit_with_drupal_layoutbuilder']['#weight'] = (float) $form['body']['#weight'] + 0.5;
  }
  else {
    $form['edit_with_drupal_layoutbuilder']['#weight'] = 50;
  }
}


/**
 * Form submit handler.
 */
function drupal_layoutbuilder_edit_with_layoutbuilder_form_submit($form, FormStateInterface &$form_state)
{
  $form_object = $form_state->getFormObject();
  // Merge submitted values into the entity (same as the main Save flow). Without
  // this, only this button's #submit runs and the in-memory entity still has
  // defaults (e.g. null title on node add), which breaks the INSERT.
  $form_object->submitForm($form, $form_state);
  $entity = $form_object->getEntity();
  // Skip basic page deployment for this save
  \Drupal::request()->attributes->set('zu_skip_basic_page_deploy', true);
  $entity->save();

  // Use watchdog() or Drupal's logging system for debugging.
  \Drupal::logger('drupal_layoutbuilder')->notice('Node @nid is saved.', ['@nid' => $entity->id()]);
  $form_state->setRedirect('drupal_layoutbuilder.editor', ['node' => $entity->id()]);
}

/**
 * Implements hook_entity_delete().
 */
function drupal_layoutbuilder_entity_delete(Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'page') {
    if (_drupal_layoutbuilder_has_data($entity->id())) {
      \Drupal\drupal_layoutbuilder\DrupalLayoutbuilderPageExporter::delete_page_json($entity);
    }
    _drupal_layoutbuilder_cleanup_webform_usage($entity->id());
  }
}

/**
 * Clean up webform_usage entries for a deleted node.
 *
 */
function _drupal_layoutbuilder_cleanup_webform_usage($nid) {
  try {
    $connection = \Drupal::database();

    if ($connection->schema()->tableExists('webform_usage')) {
      $connection->delete('webform_usage')
        ->condition('node_id', $nid)
        ->execute();
    }
  } catch (\Exception $e) {
    \Drupal::logger('drupal_layoutbuilder')->error('Error cleaning up webform_usage: @msg', ['@msg' => $e->getMessage()]);
  }
}

/**
 * Implements hook_entity_update().
 */
function drupal_layoutbuilder_entity_update(Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'page') {
    $original = $entity->original;
    if ($original && $original->isPublished() && !$entity->isPublished()) {
      \Drupal\drupal_layoutbuilder\DrupalLayoutbuilderPageExporter::delete_page_json($entity);
    }
    if (!$original || !$entity->isPublished()) {
      return;
    }

    // Only do alias-change deploy work if the alias actually changed.
    $old_alias = '';
    $new_alias = '';
    if ($original->hasField('path') && !$original->get('path')->isEmpty()) {
      $old_alias = (string) ($original->get('path')->alias ?? '');
    }
    if ($entity->hasField('path') && !$entity->get('path')->isEmpty()) {
      $new_alias = (string) ($entity->get('path')->alias ?? '');
    }
    if ($old_alias === $new_alias) {
      return;
    }

    if (!_drupal_layoutbuilder_is_deploy_enabled($entity->id())) {
      return;
    }

    $langcode = $entity->language()->getId();
    $context = _drupal_layoutbuilder_get_path_context($entity);
    $pathPrefix = $context['pathPrefix'];
    $subsite_folder = $context['subsite_folder'];
    \Drupal\drupal_layoutbuilder\DrupalLayoutbuilderPageExporter::deleteAliasJsonByPath(
      $entity,
      $langcode,
      $old_alias,
      $pathPrefix,
      $subsite_folder
    );
    $data = _drupal_layoutbuilder_get_latest_data($entity->id());
    if (!empty($data)) {
      \Drupal\drupal_layoutbuilder\DrupalLayoutbuilderPageExporter::export($entity->id(), $data);
    }
  }
}

/**
 * Implements hook_entity_predelete().
 */
function drupal_layoutbuilder_entity_predelete(\Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'page') {
    $aliases = _drupal_layoutbuilder_collect_aliases($entity);
    \Drupal::request()->attributes->set('drupal_layoutbuilder_deleted_aliases_' . $entity->id(), $aliases);
  }
}

/**
 * Load latest Elementor data for a node.
 */
function _drupal_layoutbuilder_get_latest_data(int $nid): ?array {
  static $cache = [];
  static $table_exists = null;

  if (array_key_exists($nid, $cache)) {
    return $cache[$nid];
  }

  try {
    $connection = \Drupal::database();
    if ($table_exists === null) {
      $table_exists = $connection->schema()->tableExists('drupal_layoutbuilder_data');
    }
    if (!$table_exists) {
      $cache[$nid] = null;
      return null;
    }

    $result = $connection->query(
      "SELECT data FROM drupal_layoutbuilder_data WHERE uid = :nid ORDER BY ID DESC LIMIT 1",
      [':nid' => $nid]
    )->fetch();

    if (!$result || empty($result->data)) {
      $cache[$nid] = null;
      return null;
    }

    $cache[$nid] = json_decode($result->data, true);
    return $cache[$nid];
  } catch (\Exception $e) {
    \Drupal::logger('drupal_layoutbuilder')->error('Failed to load drupal_layoutbuilder_data: @msg', ['@msg' => $e->getMessage()]);
    $cache[$nid] = null;
    return null;
  }
}

/**
 * Check if Elementor deploy is enabled for a node.
 */
function _drupal_layoutbuilder_is_deploy_enabled(int $nid): bool {
  $data = _drupal_layoutbuilder_get_latest_data($nid);
  if (!isset($data['settings']['deploy'])) {
    return FALSE;
  }
  $deploy = $data['settings']['deploy'];
  return $deploy === 'yes' || $deploy === TRUE || $deploy === 1 || $deploy === '1';
}

/**
 * Check if a node has Elementor data stored.
 */
function _drupal_layoutbuilder_has_data(int $nid): bool {
  return _drupal_layoutbuilder_get_latest_data($nid) !== null;
}

/**
 * Resolve deploy path context.
 */
function _drupal_layoutbuilder_get_path_context(\Drupal\node\NodeInterface $node): array {
  $host_name = strtolower(\Drupal::request()->getHost());
  if ($node->hasField('field_domain_access') && !$node->get('field_domain_access')->isEmpty()) {
    $domain = $node->get('field_domain_access')->entity;
    if ($domain && !empty($domain->hostname)) {
      $host_name = strtolower(trim($domain->hostname));
    }
  }

  $subsite_folder = '';
  if ($node->hasField('field_site') && !$node->get('field_site')->isEmpty()) {
    $subsite_folder = strtolower($node->field_site->entity->name->value);
  }

  $author = \Drupal\user\Entity\User::load($node->getOwnerId());
  $author_roles = $author ? $author->getRoles() : [];
  $mapped_folder = null;
  static $multidomain_records = null;
  if ($multidomain_records === null) {
    try {
      $multidomain_records = \Drupal::database()->select('zu_multidomain', 'z')
        ->fields('z', ['folder_name', 'roles'])
        ->execute()
        ->fetchAll();
    } catch (\Exception $e) {
      \Drupal::logger('drupal_layoutbuilder')->error('Folder lookup failed: @msg', ['@msg' => $e->getMessage()]);
      $multidomain_records = [];
    }
  }

  foreach ($multidomain_records as $record) {
    $record_roles = array_filter(array_map('trim', explode(',', $record->roles)));
    if (array_intersect($record_roles, $author_roles)) {
      $mapped_folder = trim($record->folder_name);
      break;
    }
  }

  $pathPrefix = !empty($mapped_folder)
    ? '/' . $mapped_folder
    : '/' . $host_name;

  return [
    'pathPrefix' => $pathPrefix,
    'subsite_folder' => $subsite_folder,
  ];
}

/**
 * Collect aliases by language for a node.
 */
function _drupal_layoutbuilder_collect_aliases(\Drupal\node\NodeInterface $node): array {
  $aliases = [];
  $path_alias_manager = \Drupal::service('path_alias.manager');
  $langcodes = array_keys($node->getTranslationLanguages());
  if (empty($langcodes)) {
    $langcodes = [$node->language()->getId()];
  }

  foreach ($langcodes as $langcode) {
    $node_lang = $node->hasTranslation($langcode) ? $node->getTranslation($langcode) : $node;
    $alias = '';
    if ($node_lang->hasField('path') && !$node_lang->get('path')->isEmpty()) {
      $alias = (string) ($node_lang->get('path')->alias ?? '');
    }
    if (empty($alias)) {
      $alias = $path_alias_manager->getAliasByPath('/node/' . $node->id(), $langcode);
    }
    if (!empty($alias) && $alias !== '/node/' . $node->id()) {
      $aliases[$langcode] = $alias;
    }
  }

  return $aliases;
}
