<?php

// Legacy bootstrap file removed; see src/DrupalLayoutbuilderPlugin.php.

use Drupal\Core\Entity\EntityFormInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\drupal_layoutbuilder\DrupalLayoutbuilderPlugin;

/**
 * Allowed node bundles for the layout builder (config: node_types).
 *
 * @return list<string>
 */
function _drupal_layoutbuilder_allowed_node_types(): array {
  $config = \Drupal::configFactory()->get('drupal_layoutbuilder.settings');
  if ($config->isNew()) {
    return _drupal_layoutbuilder_fallback_node_types();
  }
  $types = $config->get('node_types');
  if (!is_array($types)) {
    return [];
  }
  return array_values(array_filter($types, static function ($machine_name) {
    return is_string($machine_name) && $machine_name !== '' && $machine_name !== '0';
  }));
}

/**
 * Default bundles when settings were never saved (new installs, partial sync).
 *
 * @return list<string>
 */
function _drupal_layoutbuilder_fallback_node_types(): array {
  $storage = \Drupal::entityTypeManager()->getStorage('node_type');
  $out = [];
  foreach (['page', 'article', 'template'] as $id) {
    if ($storage->load($id)) {
      $out[] = $id;
    }
  }
  if ($out !== []) {
    return $out;
  }
  foreach ($storage->loadMultiple() as $type) {
    $out[] = $type->id();
  }
  return $out;
}

/**
 * Implements hook_page_attachments().
 */
function drupal_layoutbuilder_page_attachments(array &$attachments)
{
  // Elementor
  $attachments['#attached']['library'][] = 'drupal_layoutbuilder/slick-carousel';
  $attachments['#attached']['library'][] = 'drupal_layoutbuilder/global';
  $attachments['#attached']['library'][] = 'drupal_layoutbuilder/slick-init';
  $attachments['#attached']['library'][] = 'drupal_layoutbuilder/drupal_layoutbuilder_custom';
  $attachments['#attached']['library'][] = 'drupal_layoutbuilder/scroll_animation';

  // Views core libraries
  $attachments['#attached']['library'][] = 'views/views.ajax';
  $attachments['#attached']['library'][] = 'views/views.theme';

  // Views grid and responsive grid
  $attachments['#attached']['library'][] = 'views/views.grid';
  $attachments['#attached']['library'][] = 'views/views.responsive-grid';
}
/**
 * Implements hook_theme().
 */

function drupal_layoutbuilder_theme($existing, $type, $theme, $path)
{

  return [
    'drupal_layoutbuilder_field' => [
      'variables' => [
        'is_rtl' => null,
        'drupal_layoutbuilder_data' => null,
        'drupal_layoutbuilder_tmp' => null,
        'base_path' => \Drupal::request()->getBasePath()
      ],
    ],
    // 'elementor_editor' => [
