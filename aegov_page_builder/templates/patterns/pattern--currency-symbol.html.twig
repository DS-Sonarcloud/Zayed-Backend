{# AEGov Design System — Currency Symbol Pattern #}
{% if data.mode == 'display' %}
  <div class="aegov-currency">
    <span class="aegov-currency__label">{{ data.label }}:</span>
    <strong class="aegov-currency__value">{{ data.currency|default('AED') }} {{ data.value }}</strong>
  </div>
{% else %}
  <div class="aegov-form-group">
    <label for="currency-field" class="aegov-label">{{ data.label|default('Amount') }}</label>
    <div class="aegov-currency-input">
      <span class="aegov-currency-input__symbol">{{ data.currency|default('AED') }}</span>
      <input type="number" id="currency-field" name="amount" class="aegov-input"
        placeholder="{{ data.placeholder|default('0.00') }}" step="0.01" min="0">
    </div>
  </div>
{% endif %}
