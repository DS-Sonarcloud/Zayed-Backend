{# AEGov Design System — Input Component #}
<div class="aegov-form-group">
  <label for="input-{{ data.name }}" class="aegov-label">
    {{ data.label }}
    {% if data.required %}<span class="aegov-required" aria-hidden="true">*</span>{% endif %}
  </label>
  <input
    type="{{ data.type|default('text') }}"
    id="input-{{ data.name }}"
    name="{{ data.name }}"
    class="aegov-input"
    placeholder="{{ data.placeholder|default('') }}"
    {% if data.required %}required{% endif %}
    {% if data.disabled %}disabled{% endif %}>
  {% if data.helper_text %}<span class="aegov-field-helper">{{ data.helper_text }}</span>{% endif %}
</div>
