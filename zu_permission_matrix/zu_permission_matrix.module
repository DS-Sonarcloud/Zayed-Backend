<?php

/**
 * @file
 * Legacy permission groups — superseded by zu_college_permissions (FRD matrix).
 *
 * Module remains in codebase for config entity data; UI is disabled.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function zu_permission_matrix_help($route_name, RouteMatchInterface $route_match): ?string {
  if ($route_name === 'help.page.zu_permission_matrix') {
    return (string) t('This module has been replaced by the FRD Permission Matrix at @url.', [
      '@url' => '/admin/zu-permissions',
    ]);
  }
  return NULL;
}

/**
 * Implements hook_menu_links_discovered_alter().
 */
function zu_permission_matrix_menu_links_discovered_alter(array &$links): void {
  unset(
    $links['zu_permission_matrix.group_list'],
    $links['zu_permission_matrix.role_assignment_menu'],
  );
}
