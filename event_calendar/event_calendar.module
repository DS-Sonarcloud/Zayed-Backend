<?php

use Drupal\views\ViewExecutable;
use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\Core\Link;
use Drupal\flag\Entity\Flag;
use Drupal\webform\Entity\WebformSubmission;
use Symfony\Component\HttpFoundation\JsonResponse;
use Drupal\Core\Database\Database;
use Drupal\Core\Entity\EntityInterface;
use Drupal\user\Entity\User;
use Drupal\node\NodeInterface;
use Drupal\Core\Access\AccessResult;
use Drupal\Core\Session\AccountInterface;
use Drupal\webform\WebformInterface;

/**
 * Implements hook_cron().
 */
function event_calendar_cron()
{
  $queue_service = \Drupal::service('event_calendar.notification_queue');
  $processed = $queue_service->processAllPendingBatches(100);

  if ($processed > 0) {
    \Drupal::logger('event_calendar')->info('Processed @count notification queue items', ['@count' => $processed]);
  }
}

/**
 * Implements hook_form_FORM_ID_alter().  
 */
function event_calendar_form_views_exposed_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  // Check the exposed form ID for your View (use browser Inspect or View source).
  if ($form['#id'] === 'views-exposed-form-calendar-events-page-1') {
    //$form['#info']['filter-field_event_date_value']['#attributes']['class'][] = 'hide';	
    $form['field_start_date_value_wrapper']['#attributes']['class'] = "event_date_expose_fieldset";
    $form['#attached']['library'][] = 'event_calendar/event_calendar_libraries';
    $form['#attached']['library'][] = 'custom_react_calendar/react_calendar_app';
  }
  if (empty($form['#id']) || $form['#id'] !== 'views-exposed-form-event-dashboard-event-dashboard-page') {
    return;
  }

  $user = \Drupal::currentUser();
  $uid = $user->id();
  $roles = $user->getRoles();
  $is_admin = in_array('administrator', $roles) || in_array('super_admin', $roles);

  if ($is_admin) {
    return;
  }

  $account = \Drupal\user\Entity\User::load($uid);
  if (!$account->hasField('field_event_department')) {
    return;
  }
  $allowed_tids = array_column($account->get('field_event_department')->getValue(), 'target_id');

  if (isset($form['field_event_type_target_id'])) {
    $options = $form['field_event_type_target_id']['#options'];
    $new_options = ['All' => t('- Any -')];

    $can_view_dept = $user->hasPermission('view any department content') && !empty($allowed_tids);

    foreach ($options as $tid => $label) {
      if ($tid === 'All') {
        continue;
      }

      if (in_array($tid, $allowed_tids)) {
        // Show the department title only.
        $new_options[$tid] = $label;
      }
    }
    $form['field_event_type_target_id']['#options'] = $new_options;
  }
}

function event_calendar_preprocess_node(&$variables)
{
  if ($variables['node']->getType() === 'event') {
    $nid = $variables['node']->id();
    $url = Url::fromUri("internal:/event/{$nid}/calendar.ics");
    $link = Link::fromTextAndUrl('Add to Calendar (.ics)', $url)->toRenderable();
    $link['#attributes']['download'] = 'calendar.ics';
    $variables['add_to_calendar_link'] = \Drupal::service('renderer')->render($link);
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function event_calendar_form_node_event_edit_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  $node = $form_state->getFormObject()->getEntity();
  $flag_id = 'bookmark';
  $flag = Flag::load($flag_id);

  if ($flag && $node) {
    // Load flagging storage
    $flagging_storage = \Drupal::entityTypeManager()->getStorage('flagging');

    // Count how many times this node has been flagged
    $count = $flagging_storage->getQuery()
      ->accessCheck(FALSE)
      ->condition('flag_id', $flag_id)
      ->condition('entity_id', $node->id())
      ->count()
      ->execute();

    $form['bookmark_stats'] = [
      '#type' => 'details',
      '#title' => t('Bookmark Stats'),
      '#group' => 'advanced',
      '#weight' => 100,
      '#cache' => [
        'max-age' => 0,
        'tags' => ['flagging_list', "node:" . $node->id()],
      ],
    ];

    $form['bookmark_stats']['flag_count_info'] = [
      '#type' => 'markup',
      '#markup' => '<div><strong>Bookmark Events Count:</strong> ' . $count . '</div>',
    ];
  }

  if ($node && $node->hasField('field_view_count')) {
    $count = $node->get('field_view_count')->value ?? 0;
    $form['view_count_display'] = [
      '#type' => 'details',
      '#title' => t('View Event Stats'),
      '#group' => 'advanced',
      '#weight' => 101,
    ];
    $form['view_count_display']['flag_count_info'] = [
      '#type' => 'markup',
      '#markup' => '<div><strong>View Events Count:</strong> ' . $count . '</div>',
    ];
  }

  $registration_count = _event_calendar_get_registration_count($node);
  if ($registration_count > 0 || ($node->hasField('field_registration_link') && !$node->get('field_registration_link')->isEmpty()) || ($node->hasField('field_select_webform') && !$node->get('field_select_webform')->isEmpty())) {
    $form['register_count'] = [
      '#type' => 'details',
      '#title' => t('Event Registration'),
      '#group' => 'advanced',
      '#weight' => 102,
      '#cache' => [
        'max-age' => 0,
        'tags' => ['webform_submission_list', "node:" . $node->id()],
      ],
    ];
    $form['register_count']['register_count_info'] = [
      '#type' => 'markup',
      '#markup' => '<div><strong>Event Registration Count:</strong> ' . $registration_count . '</div>',
    ];
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for Event bundle.
 */
function event_calendar_form_node_form_alter(array &$form, FormStateInterface $form_state, $form_id)
{
  if ($form_state->getFormObject()->getEntity()->bundle() === 'event') {
    $form['#attached']['library'][] = 'event_calendar/event_calendar_libraries';
    $form['#validate'][] = 'event_calendar_event_form_validate';
    $form['#validate'][] = 'event_calendar_event_validate';
  }
  $node = $form_state->getFormObject()->getEntity();
  if ($node->getEntityTypeId() !== 'node' || $node->bundle() !== 'event') {
    return;
  }
  /*
  // Only add validation if the field exists on the form.
  if (isset($form['field_registration_link'])) {
    // Add our form-level validate callback.
    $form['#validate'][] = 'event_calendar_validate_registration_link';
  }
  */
}

function event_calendar_validate_registration_link(array &$form, FormStateInterface $form_state)
{
  $items = $form_state->getValue('field_registration_link');

  if (!is_array($items)) {
    return;
  }

  foreach ($items as $delta => $item) {
    // Skip non-arrays/empty values
    if (!is_array($item)) {
      continue;
    }

    $uri = $item['uri'] ?? '';
    if ($uri === '' || $uri === null) {
      continue;
    }

    // Accept ONLY internal:/form/... 
    if (!preg_match('#^internal:/form(/|$)#', $uri)) {
      // Point the error at the exact element
      $element = $form['field_registration_link'][$delta]['uri'] ?? $form['field_registration_link'];
      $form_state->setError($element, t('Registration URL starting with /form/ are allowed.'));
    }
  }
}
/**
 * Implements hook_preprocess_views_view_table().
 */
function event_calendar_preprocess_views_view_table(array &$variables)
{
  $view = $variables['view'];

  if ($view->id() !== 'event_dashboard' || $view->current_display !== 'event_dashboard_page') {
    return;
  }

  $connection = \Drupal::database();
  $storage = \Drupal::entityTypeManager()->getStorage('node');

  // --------------------------
  // USER DETAILS
  // --------------------------
  $current_user = \Drupal::currentUser();
  $current_uid = $current_user->id();
  $roles = $current_user->getRoles();
  $is_admin = in_array('administrator', $roles) || in_array('super_admin', $roles);
  $language_manager = \Drupal::languageManager();
  $current_langcode = $language_manager
    ->getCurrentLanguage(\Drupal\Core\Language\LanguageInterface::TYPE_INTERFACE)
    ->getId();
  $current_language = $language_manager->getLanguage($current_langcode);

  // Get user's allowed taxonomy term
  $allowed_tids = [];
  if (!$is_admin && $current_uid) {
    $account = \Drupal\user\Entity\User::load($current_uid);
    if ($account->hasField('field_event_department')) {
      $allowed_tids = array_column($account->get('field_event_department')->getValue(), 'target_id');
    }
  }

  // --------------------------
  // Dashboard COUNTS
  // --------------------------
  $counts = _event_calendar_get_dashboard_counts($current_user, $is_admin);

  // Check permission
  $can_manage_dashboard = $current_user->hasPermission('manage event dashboard');

  // If NO permission, remove the columns from header immediately
  if (!$can_manage_dashboard) {
    unset($variables['header']['nothing']);   // Bookmark users
    unset($variables['header']['nothing_2']); // Publish/UnPublish
    unset($variables['header']['nothing_3']); // Total Registration
  }

  $total = $counts['total'];
  $published = $counts['published'];
  $draft = $counts['draft'];
  $needs_review = $counts['needs_review'];

  // --------------------------
  // FLAGS
  // --------------------------
  $flag_id = 'bookmark';
  $subscribe_flag_id = 'subscribe_event';
  $flag = \Drupal\flag\Entity\Flag::load($flag_id);
  $flagging_storage = \Drupal::entityTypeManager()->getStorage('flagging');

  // --------------------------
  // TAXONOMY REPORT (FILTER for USER + COUNT USER EVENTS ONLY)
  // --------------------------
  $terms_to_check = \Drupal::entityTypeManager()
    ->getStorage('taxonomy_term')
    ->loadTree('event_type');

  $term_data_report = [];
  $term_subscriber_counts_legacy = [];

  foreach ($terms_to_check as $term_object) {
    $tid = $term_object->tid;
    $term_name = $term_object->name;

    // FILTER taxonomy for user
    if (!$is_admin && !in_array($tid, $allowed_tids)) {
      continue;
    }

    // COUNT EVENTS BY USER + DEPARTMENT USERS
    $node_query = \Drupal::entityQuery('node')
      ->condition('type', 'event')
      ->condition('status', 1)
      ->condition('field_event_type', $tid)
      ->accessCheck(FALSE);

    if (!$is_admin) {
      $node_query->condition('uid', 1, '<>');

      if (!empty($allowed_tids)) {
        $dept_users = \Drupal::entityTypeManager()->getStorage('user')
          ->getQuery()
          ->condition('field_event_department', $allowed_tids, 'IN')
          ->accessCheck(FALSE)
          ->execute();

        if (!empty($dept_users)) {
          $node_query->condition('uid', array_values($dept_users), 'IN');
        } else {
          $node_query->condition('uid', $current_uid);
        }
      } else {
        $node_query->condition('uid', $current_uid);
      }
    }

    $node_count = (int) $node_query->count()->execute();

    // Subscribers remain global
    $subscriber_count = 0;
    try {
      $sub_query = $connection->select('flagging', 'f');
      $sub_query->join('public_user', 'pu', 'f.uid = pu.id');
      $sub_query->addExpression('COUNT(DISTINCT f.uid)', 'total');
      $sub_query->condition('f.flag_id', $subscribe_flag_id);
      $sub_query->condition('f.entity_type', 'taxonomy_term');
      $sub_query->condition('f.entity_id', $tid);
      $subscriber_count = (int) $sub_query->execute()->fetchField();
    } catch (\Exception $e) {
    }

    $term_data_report[] = [
      'tid' => $tid,
      'term_name' => $term_name,
      'node_count' => $node_count,
      'subscriber_count' => $subscriber_count,
    ];

    $term_subscriber_counts_legacy[$tid] = $subscriber_count;
  }

  // --------------------------
  // TOTAL UNIQUE SUBSCRIBERS (GLOBAL) - only count users that exist in public_user table
  // --------------------------
  try {
    $query = $connection->select('flagging', 'f');
    $query->join('public_user', 'pu', 'f.uid = pu.id');
    $query->addExpression('COUNT(DISTINCT f.uid)', 'unique_subscribers');
    $query->condition('f.flag_id', $subscribe_flag_id);
    $query->condition('f.entity_type', 'taxonomy_term');
    $total_subscribers = (int) $query->execute()->fetchField();
  } catch (\Exception $e) {
    $total_subscribers = 0;
  }

  // --------------------------
  // MONTHLY SUBSCRIPTIONS (FILTERED FOR USER)
  // --------------------------
  $monthly_subscriptions = [];

  try {
    $results = $connection->select('flagging', 'f')
      ->fields('f', ['entity_id', 'created'])
      ->condition('f.flag_id', $subscribe_flag_id)
      ->condition('f.entity_type', 'taxonomy_term')
      ->orderBy('created', 'DESC')
      ->execute()
      ->fetchAll();

    foreach ($results as $result) {

      // FILTER BY USER TAXONOMY
      if (!$is_admin && !in_array($result->entity_id, $allowed_tids)) {
        continue;
      }

      // COUNT ONLY EVENTS CREATED BY USER IN THIS TAXONOMY
      if (!$is_admin) {
        $user_event_ids = \Drupal::entityQuery('node')
          ->condition('type', 'event')
          ->condition('uid', $current_uid)
          ->condition('field_event_type', $result->entity_id)
          ->accessCheck(FALSE)
          ->execute();

        if (empty($user_event_ids)) {
          continue; // No user event for this taxonomy -> skip
        }
      }

      $month_year = date('Y-m', $result->created);
      if (!isset($monthly_subscriptions[$month_year])) {
        $monthly_subscriptions[$month_year] = 0;
      }
      $monthly_subscriptions[$month_year]++;
    }

    ksort($monthly_subscriptions);
    $chart_labels = [];
    $chart_data = [];

    foreach ($monthly_subscriptions as $month_year => $count) {
      $timestamp = strtotime($month_year . '-01');
      $chart_labels[] = date('M Y', $timestamp);
      $chart_data[] = $count;
    }

    $monthly_chart_data = [
      'labels' => $chart_labels,
      'data' => $chart_data,
    ];
  } catch (\Exception $e) {
    $monthly_chart_data = ['labels' => [], 'data' => []];
  }

  // --------------------------
  // TABLE ROWS (unchanged)
  // --------------------------
  $flag_counts = [];
  $view_counts = [];
  $total_bookmarks = 0;
  $total_registrations = 0;

  foreach ($variables['rows'] as $row_index => &$row) {
    if (!empty($view->result[$row_index]->_entity) && $view->result[$row_index]->_entity->bundle() === 'event') {
      $node = $view->result[$row_index]->_entity;
      $node_for_lang = $node;
      if ($node instanceof \Drupal\Core\TypedData\TranslatableInterface && $node->hasTranslation($current_langcode)) {
        $node_for_lang = $node->getTranslation($current_langcode);
      }
      $can_edit_current_lang = FALSE;
      $dashboard_edit_url = '';
      if ($current_language) {
        $edit_url_object = Url::fromRoute('entity.node.edit_form', ['node' => $node->id()], [
          'language' => $current_language,
          'query' => ['destination' => '/' . $current_langcode . '/event-dashboard'],
        ]);
        $can_edit_current_lang = $edit_url_object->access($current_user, TRUE)->isAllowed();
        $dashboard_edit_url = $edit_url_object->toString();
      } else {
        $can_edit_current_lang = $node_for_lang->access('update', $current_user);
      }

      // Enforce dashboard moderation rule: once in review, only reviewer/approver
      // style permissions should see Edit.
      $effective_state = NULL;
      if ($storage instanceof \Drupal\Core\Entity\RevisionableStorageInterface) {
        $latest_id_for_access = $storage->getLatestRevisionId($node->id());
        if ($latest_id_for_access) {
          $latest_for_access = $storage->loadRevision($latest_id_for_access);
          if (
            $latest_for_access instanceof NodeInterface &&
            $latest_for_access->hasField('moderation_state') &&
            !$latest_for_access->get('moderation_state')->isEmpty()
          ) {
            $effective_state = (string) $latest_for_access->get('moderation_state')->value;
          }
        }
      }
      if ($effective_state === NULL && $node_for_lang->hasField('moderation_state') && !$node_for_lang->get('moderation_state')->isEmpty()) {
        $effective_state = (string) $node_for_lang->get('moderation_state')->value;
      }

      if ($effective_state === 'needs_review') {
        $can_review_needs_review = (
          $current_user->hasPermission('edit any department content') ||
          $current_user->hasPermission('use event_workflow transition needs_review_to_published') ||
          $current_user->hasPermission('use event_workflow transition needs_review_to_draft') ||
          $current_user->hasPermission('use event_workflow transition needs_review_to_needs_review') ||
          $current_user->hasPermission('use events_work_flow transition need_review_to_published') ||
          $current_user->hasPermission('use events_work_flow transition reviewer_to_draft')
        );
        if (!$can_review_needs_review) {
          $can_edit_current_lang = FALSE;
        }
      }

      $row['can_edit_current_lang'] = (bool) $can_edit_current_lang;
      $row['dashboard_langcode'] = $current_langcode;
      $row['dashboard_edit_url'] = $dashboard_edit_url;
      $row['dashboard_title'] = $node_for_lang->label();
      if ($current_language) {
        $row['dashboard_node_url'] = Url::fromRoute('entity.node.canonical', ['node' => $node->id()], [
          'language' => $current_language,
        ])->toString();
      } else {
        $row['dashboard_node_url'] = Url::fromRoute('entity.node.canonical', ['node' => $node->id()])->toString();
      }

      $bookmark_count = 0;
      if ($flag) {
        try {
          $bookmark_count = $flagging_storage->getQuery()
            ->accessCheck(FALSE)
            ->condition('flag_id', $flag_id)
            ->condition('entity_type', 'node')
            ->condition('entity_id', $node->id())
            ->count()
            ->execute();
        } catch (\Exception $e) {
        }
      }

      $total_bookmarks += $bookmark_count;

      $view_count = $node->hasField('field_view_count') ? (int) $node->get('field_view_count')->value : 0;

      $flag_counts[$node->id()] = $bookmark_count;
      $view_counts[$node->id()] = $view_count;

      // Registration count
      $registration_count = _event_calendar_get_registration_count($node);

      $total_registrations += $registration_count;

      $row['#registration_count'] = $registration_count;
      $row['#bookmark_count'] = $bookmark_count;
      $row['#view_count'] = $view_count;

      // Normalize dashboard "Edit" action for current language and permissions.
      if (isset($row['columns']['nothing_1']['content'][0]['field_output'])) {
        $actions_output = &$row['columns']['nothing_1']['content'][0]['field_output'];
        $actions_markup = '';

        if (is_array($actions_output) && isset($actions_output['#markup'])) {
          $actions_markup = (string) $actions_output['#markup'];
        } elseif (is_string($actions_output)) {
          $actions_markup = $actions_output;
        }

        if ($actions_markup !== '') {
          if (!$can_edit_current_lang) {
            $actions_markup = preg_replace(
              '#<a\b[^>]*\bclass="[^"]*\bdashboard-edit-node\b[^"]*"[^>]*>.*?</a>#is',
              '',
              $actions_markup
            );
          } elseif (!empty($dashboard_edit_url)) {
            $actions_markup = preg_replace_callback(
              '#<a\b([^>]*)\bclass="([^"]*\bdashboard-edit-node\b[^"]*)"([^>]*)>#i',
              static function ($matches) use ($dashboard_edit_url) {
                $attrs = $matches[1] . ' class="' . $matches[2] . '"' . $matches[3];
                if (preg_match('#\bhref=("|\').*?\1#i', $attrs)) {
                  $attrs = preg_replace(
                    '#\bhref=("|\').*?\1#i',
                    'href="' . htmlspecialchars($dashboard_edit_url, ENT_QUOTES, 'UTF-8') . '"',
                    $attrs
                  );
                } else {
                  $attrs .= ' href="' . htmlspecialchars($dashboard_edit_url, ENT_QUOTES, 'UTF-8') . '"';
                }
                return '<a' . $attrs . '>';
              },
              $actions_markup
            );
          }

          $actions_markup = trim($actions_markup);
          if (is_array($actions_output)) {
            $actions_output['#markup'] = $actions_markup;
          } else {
            $actions_output = $actions_markup;
          }
        }
      }

      /** @var \Drupal\Core\Entity\RevisionableStorageInterface $storage */
      if ($can_manage_dashboard) {
        // Check latest revision to determine the correct label for the toggle button.
        $latest_id = $storage->getLatestRevisionId($node->id());
        $latest = $latest_id ? $storage->loadRevision($latest_id) : $node;
        $is_published = ($latest->hasField('moderation_state') && $latest->get('moderation_state')->value === 'published');

        $label = $is_published ? t('Unpublish') : t('Publish');
        $class = $is_published ? 'toggle-Unpublish' : 'toggle-Publish';
        $nid = $node->id();

        $url = \Drupal\Core\Url::fromUserInput("/toggle-publish/$nid");
        $url->setOption('attributes', [
          'class' => ['use-ajax', $class],
          'id' => 'toggle-publish-' . $nid,
        ]);
        $url->setOption('query', ['t' => time()]);

        $link_html = \Drupal\Core\Link::fromTextAndUrl($label, $url)->toString();
        $wrapper = '<div id="toggle-wrapper-' . $nid . '">' . $link_html . '</div>';

        if (isset($row['columns']['nothing_2']['content'][0])) {
          $row['columns']['nothing_2']['content'][0]['field_output']['#markup'] = $wrapper;
        }

        if (isset($row['columns']['nothing_3']['content'][0])) {
          // Generate link to webform submissions
          $webform_id = $node->hasField('field_select_webform') ? $node->get('field_select_webform')->target_id : NULL;

          if ($webform_id && $registration_count > 0) {
            $webform_url = \Drupal\Core\Url::fromRoute(
              'entity.webform.results_submissions',
              ['webform' => $webform_id],
              ['attributes' => ['target' => '_blank']]
            );
            $webform_link = \Drupal\Core\Link::fromTextAndUrl($registration_count, $webform_url);
            $webform_link_html = $webform_link->toString();
            $row['columns']['nothing_3']['content'][0]['field_output']['#markup'] = $webform_link_html;
          } else {
            $row['columns']['nothing_3']['content'][0]['field_output']['#markup'] = $registration_count;
          }
        }
      } else {
        unset($row['columns']['nothing']);   // Bookmark users
        unset($row['columns']['nothing_2']); // Publish/UnPublish
        unset($row['columns']['nothing_3']); // Total Registration
      }
    }
  }

  // --------------------------
  // ASSIGN VARIABLES TO TWIG
  // --------------------------
  $variables['total_events'] = $total;
  $variables['published_events'] = $published;
  $variables['draft_events'] = $draft;
  $variables['needs_review_events'] = $needs_review;

  $variables['flag_counts'] = $flag_counts;
  $variables['view_counts'] = $view_counts;
  $variables['total_bookmarks'] = $total_bookmarks;
  $variables['total_registrations'] = $total_registrations;

  $variables['total_subscribers'] = $total_subscribers;
  $variables['term_data_report'] = $term_data_report;
  $variables['monthly_chart_data'] = $monthly_chart_data;
  $variables['term_subscriber_counts'] = $term_subscriber_counts_legacy;

  // Build taxonomy display
  $taxonomy_data = [];
  foreach ($term_data_report as $item) {
    $taxonomy_data[] = [
      'term_name' => ['#markup' => $item['term_name']],
      'term_count' => ['#markup' => $item['node_count']],
    ];
  }

  $variables['taxonomy_terms'] = $taxonomy_data;

  $variables['#attached']['drupalSettings']['eventCalendar'] = [
    'dailyChartData' => $monthly_chart_data,
  ];
}

/**
 * Implements hook_mail().
 */
function event_calendar_mail($key, &$message, $params)
{
  switch ($key) {
    case 'manual_event_notification':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['message'];
      break;
  }
}

function event_calendar_preprocess_views_view(array &$variables)
{
  $view = $variables['view'];

  if ($view->id() !== 'event_dashboard' || $view->current_display !== 'event_dashboard_page') {
    return;
  }

  $connection = \Drupal::database();
  $storage = \Drupal::entityTypeManager()->getStorage('node');

  // Load current user + roles
  $current_user = \Drupal::currentUser();
  $current_uid = $current_user->id();
  $roles = $current_user->getRoles();

  $is_admin = in_array('administrator', $roles) || in_array('super_admin', $roles);

  //  Get user allowed taxonomy terms
  $allowed_tids = [];
  if (!$is_admin && $current_uid) {
    $account = \Drupal\user\Entity\User::load($current_uid);
    if ($account->hasField('field_event_department')) {
      $allowed_tids = array_column($account->get('field_event_department')->getValue(), 'target_id');
    }
  }

  // ---------------------------
  // DASHBOARD COUNTS
  // ---------------------------
  $counts = _event_calendar_get_dashboard_counts($current_user, $is_admin);
  $can_view_dept = $current_user->hasPermission('view any department content') && !empty($allowed_tids);

  // ---------------------------
  // TAXONOMY REPORT (Department Wise)
  // ---------------------------
  $terms_to_check = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadTree('event_type');
  $term_data_report = [];
  $term_subscriber_counts_legacy = [];
  $taxonomy_data = [];

  $flagging_storage = \Drupal::entityTypeManager()->getStorage('flagging');
  $subscribe_flag_id = 'subscribe_event';

  foreach ($terms_to_check as $term_object) {
    if (!$is_admin && !in_array($term_object->tid, $allowed_tids)) {
      continue;
    }

    $tid = $term_object->tid;
    $term_name = $term_object->name;

    $node_query = \Drupal::entityQuery('node')
      ->condition('type', 'event')
      ->condition('status', 1)
      ->condition('field_event_type', $tid)
      ->accessCheck(FALSE);

    if (!$is_admin) {
      $node_query->condition('uid', 1, '<>');

      if ($can_view_dept) {
        $dept_users = \Drupal::entityTypeManager()->getStorage('user')
          ->getQuery()
          ->condition('field_event_department', $allowed_tids, 'IN')
          ->accessCheck(FALSE)
          ->execute();

        if (!empty($dept_users)) {
          $node_query->condition('uid', array_values($dept_users), 'IN');
        } else {
          $node_query->condition('uid', $current_uid);
        }
      } else {
        $node_query->condition('uid', $current_uid);
      }
    }

    $node_count = (int) $node_query->count()->execute();

    // Only count users that exist in public_user table
    $subscriber_count = 0;
    try {
      $sub_query = $connection->select('flagging', 'f');
      $sub_query->join('public_user', 'pu', 'f.uid = pu.id');
      $sub_query->addExpression('COUNT(DISTINCT f.uid)', 'total');
      $sub_query->condition('f.flag_id', $subscribe_flag_id);
      $sub_query->condition('f.entity_type', 'taxonomy_term');
      $sub_query->condition('f.entity_id', $tid);
      $subscriber_count = (int) $sub_query->execute()->fetchField();
    } catch (\Exception $e) {
    }

    $term_data_report[] = [
      'tid' => $tid,
      'term_name' => $term_name,
      'node_count' => $node_count,
      'subscriber_count' => $subscriber_count,
    ];
    $term_subscriber_counts_legacy[$tid] = $subscriber_count;

    $taxonomy_data[] = [
      'term_name' => ['#markup' => $term_name],
      'term_count' => ['#markup' => $node_count],
    ];
  }

  // ---------------------------
  // TOTAL UNIQUE SUBSCRIBERS
  // ---------------------------
  try {
    $query = $connection->select('flagging', 'f');
    $query->join('public_user', 'pu', 'f.uid = pu.id');
    $query->addExpression('COUNT(DISTINCT f.uid)', 'unique_subscribers');
    $query->condition('f.flag_id', $subscribe_flag_id);
    $query->condition('f.entity_type', 'taxonomy_term');
    $total_subscribers = (int) $query->execute()->fetchField();
  } catch (\Exception $e) {
    $total_subscribers = 0;
  }

  // ---------------------------
  // MONTHLY SUBSCRIPTIONS (filtered)
  // ---------------------------
  $monthly_subscriptions = [];
  try {
    $results = $connection->select('flagging', 'f')
      ->fields('f', ['entity_id', 'created'])
      ->condition('f.flag_id', $subscribe_flag_id)
      ->condition('f.entity_type', 'taxonomy_term')
      ->orderBy('created', 'DESC')
      ->execute()
      ->fetchAll();

    foreach ($results as $result) {
      if (!$is_admin && !in_array($result->entity_id, $allowed_tids)) {
        continue;
      }
      $month_year = date('Y-m', $result->created);
      if (!isset($monthly_subscriptions[$month_year])) {
        $monthly_subscriptions[$month_year] = 0;
      }
      $monthly_subscriptions[$month_year]++;
    }

    ksort($monthly_subscriptions);
    $chart_labels = [];
    $chart_data = [];
    foreach ($monthly_subscriptions as $month_year => $count) {
      $chart_labels[] = date('M Y', strtotime($month_year . '-01'));
      $chart_data[] = $count;
    }
    $monthly_chart_data = ['labels' => $chart_labels, 'data' => $chart_data];
  } catch (\Exception $e) {
    $monthly_chart_data = ['labels' => [], 'data' => []];
  }

  // ---------------------------
  // BOOKMARK COUNTS
  // ---------------------------
  try {
    $bookmark_query = $connection->select('flagging', 'f');
    $bookmark_query->join('node_field_data', 'n', 'f.entity_id = n.nid AND n.default_langcode = 1');
    $bookmark_query->addExpression('COUNT(f.id)', 'total');
    $bookmark_query->condition('f.flag_id', 'bookmark');
    $bookmark_query->condition('f.entity_type', 'node');
    $bookmark_query->condition('n.type', 'event');
    $total_bookmarks = (int) $bookmark_query->execute()->fetchField();
  } catch (\Exception $e) {
    $total_bookmarks = 0;
  }

  // ---------------------------
  // ASSIGN TWIG VARIABLES
  // ---------------------------
  $variables['user_event_stats'] = $counts;
  $variables['total_events'] = $counts['total'];
  $variables['published_events'] = $counts['published'];
  $variables['draft_events'] = $counts['draft'];
  $variables['needs_review_events'] = $counts['needs_review'];

  $variables['total_bookmarks'] = $total_bookmarks;
  $variables['total_subscribers'] = $total_subscribers;
  $variables['term_data_report'] = $term_data_report;
  $variables['taxonomy_terms'] = $taxonomy_data;
  $variables['monthly_chart_data'] = $monthly_chart_data;
  $variables['user_roles'] = $roles;

  $variables['#attached']['drupalSettings']['eventCalendar'] = [
    'dailyChartData' => $monthly_chart_data,
  ];

  $variables['manual_notification_form'] = \Drupal::formBuilder()->getForm(
    \Drupal\event_calendar\Form\EventNotificationForm::class
  );
}




/**
 * Start Date and End Date validation in event form.
 * 
 */

function convert_seconds_to_time($seconds)
{
  if ($seconds === NULL || $seconds === '') {
    return NULL;
  }
  return gmdate("H:i", (int) $seconds);
}

function event_calendar_event_validate($form, \Drupal\Core\Form\FormStateInterface $form_state)
{
  $start_date_raw = $form_state->getValue('field_start_date')[0]['value'] ?? NULL;
  $end_date_raw = $form_state->getValue('field_end_date')[0]['value'] ?? NULL;

  if (!$start_date_raw || !$end_date_raw) {
    return;
  }

  $start_date = substr($start_date_raw, 0, 10);
  $end_date = substr($end_date_raw, 0, 10);

  $start_time_raw = $form_state->getValue('field_start_time')[0]['value'] ?? NULL;
  $end_time_raw = $form_state->getValue('field_end_time')[0]['value'] ?? NULL;

  $has_start_time = ($start_time_raw !== NULL && $start_time_raw !== '');
  $has_end_time = ($end_time_raw !== NULL && $end_time_raw !== '');

  $start_time = convert_seconds_to_time($start_time_raw) ?: '00:00';
  $end_time = convert_seconds_to_time($end_time_raw) ?: '00:00';

  try {
    $now = new \DateTime();
    $today_date = $now->format('Y-m-d');

    $start_dt = new \DateTime("$start_date $start_time");
    $end_dt = new \DateTime("$end_date $end_time");

    $node = $form_state->getFormObject()->getEntity();

    $needs_validation = $node->isNew();
    if (!$node->isNew()) {
      $original_node = \Drupal::entityTypeManager()->getStorage('node')->loadUnchanged($node->id());
      if ($original_node) {
        $original_start_date = $original_node->hasField('field_start_date') ? substr($original_node->get('field_start_date')->value, 0, 10) : '';
        $original_start_time_raw = $original_node->hasField('field_start_time') ? $original_node->get('field_start_time')->value : NULL;

        if ($original_start_date !== $start_date || (string)$original_start_time_raw !== (string)$start_time_raw) {
          $needs_validation = TRUE;
        }
      }
    }

    if ($needs_validation) {
      if ($has_start_time) {
        if ($start_dt < $now) {
          $form_state->setErrorByName('field_start_date', t('Start date and time cannot be in the past.'));
          return;
        }
      } else {
        if ($start_date < $today_date) {
          $form_state->setErrorByName('field_start_date', t('Start date cannot be in the past.'));
          return;
        }
      }
    }
  } catch (\Exception $e) {
    $form_state->setErrorByName('field_start_date', t('Invalid date or time format.'));
    return;
  }

  if ($start_date > $end_date) {
    $form_state->setErrorByName('field_end_date', t('End date cannot be earlier than start date.'));
    return;
  }

  if ($start_date === $end_date) {
    if ($has_start_time && $has_end_time) {
      if ($start_time_raw >= $end_time_raw) {
        $form_state->setErrorByName('field_end_time', t('On the same date, end time must be later than start time.'));
        return;
      }
    }
  }

  if ($start_dt > $end_dt) {
    $form_state->setErrorByName('field_end_time', t('End date/time must be after start date/time.'));
  }
}


/**
 * Implements hook_entity_insert().
 */
function event_calendar_entity_insert(EntityInterface $entity)
{
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'event') {
    return;
  }

  $new_webform_id = _event_calendar_get_webform_id($entity);
  if ($new_webform_id) {
    _event_calendar_save_usage($new_webform_id, $entity->id());
  }
}

/**
 * Implements hook_entity_update().
 */
function event_calendar_entity_update(EntityInterface $entity)
{
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'event') {
    return;
  }

  $new_webform_id = _event_calendar_get_webform_id($entity);
  $old_webform_id = _event_calendar_get_webform_id($entity->original);
  if ($old_webform_id && $new_webform_id && $old_webform_id !== $new_webform_id) {
    _event_calendar_delete_usage($old_webform_id);
    _event_calendar_save_usage($new_webform_id, $entity->id());
    return;
  }
  if ($new_webform_id && $new_webform_id === $old_webform_id) {
    _event_calendar_save_usage($new_webform_id, $entity->id());
  }
}

/**
 * Implements hook_entity_delete().
 */
function event_calendar_entity_delete(EntityInterface $entity)
{
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'event') {
    return;
  }

  $webform_id = _event_calendar_get_webform_id($entity);

  if ($webform_id) {
    _event_calendar_delete_usage($webform_id);
  }
}

function _event_calendar_get_webform_id($entity)
{
  if (!$entity || !$entity->hasField('field_select_webform')) {
    return NULL;
  }

  $value = $entity->get('field_select_webform')->getValue();

  return isset($value[0]['target_id']) ? (string) $value[0]['target_id'] : NULL;
}

/**
 * Mark a webform as used.
 */
function _event_calendar_save_usage($webform_id, $node_id)
{
  $timestamp = time();
  $user_id = \Drupal::currentUser()->id();

  \Drupal::database()->query("
    INSERT INTO webform_usage (webform_id, node_id, used, used_at, updated_at, user_id)
    VALUES (:webform_id, :node_id, 1, :used_at, :updated_at, :user_id)
    ON DUPLICATE KEY UPDATE
      node_id = VALUES(node_id),
      used_at = VALUES(used_at),
      updated_at = VALUES(updated_at),
      user_id = VALUES(user_id)
  ", [
    ':webform_id' => $webform_id,
    ':node_id' => $node_id,
    ':used_at' => $timestamp,
    ':updated_at' => $timestamp,
    ':user_id' => $user_id,
  ]);
}

function _event_calendar_delete_usage($webform_id)
{
  \Drupal::database()->delete('webform_usage')
    ->condition('webform_id', $webform_id)
    ->execute();
}

function event_calendar_event_form_validate($form, \Drupal\Core\Form\FormStateInterface $form_state)
{
  $values = $form_state->getValue('field_select_webform');
  $new_webform_id = isset($values[0]['target_id']) ? $values[0]['target_id'] : NULL;

  if (!$new_webform_id) {
    return;
  }

  $existing_node_id = \Drupal::database()
    ->select('webform_usage', 'wu')
    ->fields('wu', ['node_id'])
    ->condition('webform_id', $new_webform_id)
    ->execute()
    ->fetchField();

  $current_node = $form_state->getFormObject()->getEntity();
  $current_node_id = $current_node->id();

  if ($existing_node_id && $existing_node_id != $current_node_id) {
    $form_state->setErrorByName(
      'field_select_webform',
      t('This webform is already assigned to another event and cannot be selected again.')
    );
  }
}

/**
 * Returns filtered event counts for the dashboard.
 */
function _event_calendar_get_dashboard_counts($account, $is_admin)
{
  $database = \Drupal::database();
  $uid = $account->id();
  $counts = [
    'total' => 0,
    'published' => 0,
    'draft' => 0,
    'needs_review' => 0,
  ];

  $user_entity = \Drupal\user\Entity\User::load($uid);

  // Get user departments
  $allowed_tids = [];
  if ($user_entity && $user_entity->hasField('field_event_department')) {
    $allowed_tids = array_column($user_entity->get('field_event_department')->getValue(), 'target_id');
  }

  $can_view_dept = $account->hasPermission('view any department content') && !empty($allowed_tids);
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();

  // Total Count
  $t_sql = "SELECT COUNT(DISTINCT n.nid) 
            FROM {node_field_data} n 
            WHERE n.type = 'event' AND n.langcode = :lang";
  $t_params = [':lang' => $langcode];

  if (!$is_admin) {
    $t_sql .= " AND n.uid <> 1";

    if ($can_view_dept) {
      // dept user sees own content OR department content (non-draft) created by users in same department
      $t_sql .= " AND n.nid IN (SELECT entity_id FROM {node__field_event_type} WHERE field_event_type_target_id IN (:tids[]))";
      $t_sql .= " AND (n.uid = :uid OR (n.uid IN (SELECT entity_id FROM {user__field_event_department} WHERE field_event_department_target_id IN (:tids[])) AND n.nid IN (SELECT content_entity_id FROM {content_moderation_state_field_data} WHERE moderation_state <> 'draft' AND content_entity_type_id = 'node')))";
      $t_params[':uid'] = $uid;
      $t_params[':tids[]'] = $allowed_tids;
    } else {
      $t_sql .= " AND n.uid = :uid";
      $t_params[':uid'] = $uid;
    }
  }
  $counts['total'] = (int) $database->query($t_sql, $t_params)->fetchField();

  // Published count should follow moderation state to stay consistent with
  // dashboard state-based totals.
  $p_sql = "SELECT COUNT(DISTINCT n.nid)
            FROM {node_field_data} n
            INNER JOIN {content_moderation_state_field_data} cms
              ON n.nid = cms.content_entity_id AND n.langcode = cms.langcode
            WHERE n.type = 'event'
              AND n.langcode = :lang
              AND cms.content_entity_type_id = 'node'
              AND cms.moderation_state = 'published'";
  $p_params = [':lang' => $langcode];
  if (!$is_admin) {
    $p_sql .= " AND n.uid <> 1";
    if ($can_view_dept) {
      $p_sql .= " AND n.nid IN (SELECT entity_id FROM {node__field_event_type} WHERE field_event_type_target_id IN (:tids[]))";
      $p_sql .= " AND (n.uid = :uid OR n.uid IN (SELECT entity_id FROM {user__field_event_department} WHERE field_event_department_target_id IN (:tids[])))";
      $p_params[':uid'] = $uid;
      $p_params[':tids[]'] = $allowed_tids;
    } else {
      $p_sql .= " AND n.uid = :uid";
      $p_params[':uid'] = $uid;
    }
  }
  $counts['published'] = (int) $database->query($p_sql, $p_params)->fetchField();

  $base_sql = "SELECT COUNT(DISTINCT n.nid) 
               FROM {node_field_data} n
               INNER JOIN {content_moderation_state_field_data} cms ON n.nid = cms.content_entity_id AND n.langcode = cms.langcode
               WHERE n.type = 'event' AND n.langcode = :lang AND cms.content_entity_type_id = 'node'";

  $base_params = [':lang' => $langcode];

  if (!$is_admin) {
    $base_sql .= " AND n.uid <> 1";
  }

  // Needs Review Count
  $nr_sql = $base_sql . " AND cms.moderation_state = 'needs_review'";
  $nr_params = $base_params;
  if (!$is_admin) {
    if ($can_view_dept) {
      $nr_sql .= " AND n.nid IN (SELECT entity_id FROM {node__field_event_type} WHERE field_event_type_target_id IN (:tids[]))";
      $nr_sql .= " AND (n.uid = :uid OR n.uid IN (SELECT entity_id FROM {user__field_event_department} WHERE field_event_department_target_id IN (:tids[])))";
      $nr_params[':uid'] = $uid;
      $nr_params[':tids[]'] = $allowed_tids;
    } else {
      $nr_sql .= " AND n.uid = :uid";
      $nr_params[':uid'] = $uid;
    }
  }
  $counts['needs_review'] = (int) $database->query($nr_sql, $nr_params)->fetchField();

  // Drafts
  $d_sql = $base_sql . " AND cms.moderation_state = 'draft'";
  $d_params = $base_params;
  if (!$is_admin) {
    $d_sql .= " AND n.uid = :uid";
    $d_params[':uid'] = $uid;
  }
  $counts['draft'] = (int) $database->query($d_sql, $d_params)->fetchField();

  return $counts;
}

/**
 * Helper to get registration count for a node.
 */
function _event_calendar_get_registration_count($node)
{
  if (!$node instanceof \Drupal\node\NodeInterface) {
    return 0;
  }

  $webform_id = NULL;

  if ($node->hasField('field_select_webform') && !$node->get('field_select_webform')->isEmpty()) {
    $webform_id = $node->get('field_select_webform')->target_id;
  }
  // Check field_registration_link 
  elseif ($node->hasField('field_registration_link') && !$node->get('field_registration_link')->isEmpty()) {
    $uri = $node->get('field_registration_link')->uri;
    if (preg_match('#^internal:/form/([\w_-]+)$#', $uri, $matches)) {
      $webform_id = str_replace('-', '_', $matches[1]);
    }
  }

  if ($webform_id) {
    try {
      $submission_storage = \Drupal::entityTypeManager()->getStorage('webform_submission');
      $query = $submission_storage->getQuery()
        ->condition('webform_id', $webform_id)
        ->accessCheck(FALSE);

      $query->condition('entity_type', 'node')
        ->condition('entity_id', $node->id());

      $count = (int) $query->count()->execute();

      if ($count === 0) {
        $usage_node_id = \Drupal::database()
          ->select('webform_usage', 'wu')
          ->fields('wu', ['node_id'])
          ->condition('webform_id', $webform_id)
          ->execute()
          ->fetchField();

        if ($usage_node_id == $node->id()) {
          $query = $submission_storage->getQuery()
            ->condition('webform_id', $webform_id)
            ->accessCheck(FALSE)
            ->count();
          $count = (int) $query->execute();
        }
      }
      return $count;
    } catch (\Exception $e) {
      \Drupal::logger('event_calendar')->error('Error getting registration count for node @nid: @message', [
        '@nid' => $node->id(),
        '@message' => $e->getMessage(),
      ]);
    }
  }

  return 0;
}
