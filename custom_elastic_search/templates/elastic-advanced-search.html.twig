{#
  Elastic advanced search — UAE Government Design System.
  variables: embedded (bool) — TRUE when rendered inside Super Admin Dashboard.
  Note: standalone page title/subtitle rendered by Drupal theme, not here.
#}
<div class="eas-page{% if embedded %} eas-page--embedded{% endif %}">

  {% if embedded %}
  {# ── Dashboard compact layout ──────────────────────────────────────────── #}
  <div class="eas-compact">

    {# Row 1: input + Search button #}
    <div class="eas-compact__row">
      <div class="eas-input-wrap elastic-advanced-search__input-wrap">
        <span class="eas-input-prefix" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256">
            <path d="M229.66,218.34l-50.07-50.07a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.31ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/>
          </svg>
        </span>
        <input
          class="eas-input"
          id="srch_term"
          type="search"
          autocomplete="off"
          placeholder="{{ 'Search site content…'|t }}"
          aria-label="{{ 'Search keywords'|t }}"
        >
        <button
          type="button"
          id="voice-search-btn-advance"
          class="eas-voice-btn"
          title="{{ 'Voice search'|t }}"
          aria-label="{{ 'Search by voice'|t }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 1 0-6 0v6a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 14 0h-2zM11 18.93V22h2v-3.07A8.001 8.001 0 0 0 19.938 13H17.9a6.002 6.002 0 0 1-11.8 0H4.062A8.001 8.001 0 0 0 11 18.93z"/>
          </svg>
        </button>
      </div>
      <button type="button" class="eas-btn-primary" id="sbmt">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M229.66,218.34l-50.07-50.07a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.31ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/>
        </svg>
        {{ 'Search'|t }}
      </button>
    </div>

    {# Row 2: mode toggle #}
    <div class="eas-compact__meta">
      <fieldset class="eas-fieldset">
        <legend class="eas-compact__meta-label">{{ 'Mode:'|t }}</legend>
        <div class="eas-mode-pills">
          <label class="eas-mode-pill">
            <input type="radio" name="query_mode" value="OR" checked>
            <span>{{ 'Any word (OR)'|t }}</span>
          </label>
          <label class="eas-mode-pill">
            <input type="radio" name="query_mode" value="AND">
            <span>{{ 'All words (AND)'|t }}</span>
          </label>
        </div>
      </fieldset>
    </div>

  </div>

  {% else %}
  {# ── Standalone page layout ─────────────────────────────────────────────── #}
  <div class="eas-panel">

    {# Search input #}
    <div class="eas-form-group">
      <label class="eas-label" for="srch_term">{{ 'Search keyword'|t }}</label>
      <div class="eas-input-wrap elastic-advanced-search__input-wrap">
        <span class="eas-input-prefix" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
            <path d="M229.66,218.34l-50.07-50.07a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.31ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/>
          </svg>
        </span>
        <input
          class="eas-input"
          id="srch_term"
          type="search"
          autocomplete="off"
          placeholder="{{ 'Enter keywords…'|t }}"
          aria-label="{{ 'Search keywords'|t }}"
        >
        <button
          type="button"
          id="voice-search-btn-advance"
          class="eas-voice-btn"
          title="{{ 'Voice search'|t }}"
          aria-label="{{ 'Search by voice'|t }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 1 0-6 0v6a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 14 0h-2zM11 18.93V22h2v-3.07A8.001 8.001 0 0 0 19.938 13H17.9a6.002 6.002 0 0 1-11.8 0H4.062A8.001 8.001 0 0 0 11 18.93z"/>
          </svg>
        </button>
      </div>
    </div>

    {# Search mode #}
    <fieldset class="eas-form-group eas-fieldset">
      <legend class="eas-label">{{ 'Search mode'|t }}</legend>
      <div class="eas-mode-pills">
        <label class="eas-mode-pill">
          <input type="radio" name="query_mode" value="OR" checked>
          <span>{{ 'Any word (OR)'|t }}</span>
        </label>
        <label class="eas-mode-pill">
          <input type="radio" name="query_mode" value="AND">
          <span>{{ 'All words (AND)'|t }}</span>
        </label>
      </div>
    </fieldset>

    {# Submit + Filter toggle row #}
    <div class="eas-submit-row">
      <button type="button" class="eas-btn-primary" id="sbmt">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M229.66,218.34l-50.07-50.07a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.31ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/>
        </svg>
        {{ 'Search'|t }}
      </button>
      <button
        type="button"
        class="eas-filter-toggle"
        id="eas-filter-toggle"
        aria-expanded="false"
        aria-controls="eas-filter-panel"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M230.6,49.53A15.81,15.81,0,0,0,216,40H40A16,16,0,0,0,28.19,66.76l.08.09L96,139.17V216a16,16,0,0,0,24.87,13.32l32-21.34A16,16,0,0,0,160,194.66V139.17l67.74-72.32.08-.09A15.8,15.8,0,0,0,230.6,49.53ZM146.34,128.71A16,16,0,0,0,144,136v58.66L112,216V136a16,16,0,0,0-4.32-10.95L40,56H216Z"/>
        </svg>
        {{ 'Filters'|t }}
        <span class="eas-filter-caret" aria-hidden="true">&#9660;</span>
        <span class="eas-filter-chip" id="eas-filter-chip" hidden>0</span>
      </button>
    </div>
  </div>

  {# ── Filter panel (standalone only) ─────────────────────────────────────── #}
  <section
    class="eas-filter-panel"
    id="eas-filter-panel"
    aria-label="{{ 'Search filters'|t }}"
    hidden
  >

    {# Content Type #}
    <div class="eas-filter-section">
      <h3 class="eas-filter-section__heading">{{ 'Content Type'|t }}</h3>
      <div class="eas-filter-grid">
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="page">
          <span>{{ 'Pages'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="news">
          <span>{{ 'News'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="event">
          <span>{{ 'Events'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="faculty_staff">
          <span>{{ 'Faculty & Staff'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="blogs">
          <span>{{ 'Blogs'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="jobs">
          <span>{{ 'Jobs'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="courses">
          <span>{{ 'Courses'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="programs">
          <span>{{ 'Programs'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="colleges">
          <span>{{ 'Colleges'|t }}</span>
        </label>
        <label class="eas-filter-check">
          <input type="checkbox" class="eas-filter-type" value="file">
          <span>{{ 'Documents & Media'|t }}</span>
        </label>
      </div>
    </div>

    {# Date Range #}
    <div class="eas-filter-section">
      <h3 class="eas-filter-section__heading">{{ 'Date Range'|t }}</h3>
      <div class="eas-filter-date-row">
        <div class="eas-filter-date-group">
          <label class="eas-filter-date-label" for="eas-filter-date-from">{{ 'From'|t }}</label>
          <input
            type="date"
            id="eas-filter-date-from"
            class="eas-filter-date-from eas-input eas-input--date"
            aria-label="{{ 'Date from'|t }}"
          >
        </div>
        <span class="eas-filter-date-sep" aria-hidden="true">&ndash;</span>
        <div class="eas-filter-date-group">
          <label class="eas-filter-date-label" for="eas-filter-date-to">{{ 'To'|t }}</label>
          <input
            type="date"
            id="eas-filter-date-to"
            class="eas-filter-date-to eas-input eas-input--date"
            aria-label="{{ 'Date to'|t }}"
          >
        </div>
      </div>
    </div>

    {# Language #}
    <div class="eas-filter-section">
      <h3 class="eas-filter-section__heading">{{ 'Language'|t }}</h3>
      <div class="eas-mode-pills eas-filter-lang-pills">
        <label class="eas-mode-pill">
          <input type="radio" name="filter_langcode" class="eas-filter-lang" value="" checked>
          <span>{{ 'All'|t }}</span>
        </label>
        <label class="eas-mode-pill">
          <input type="radio" name="filter_langcode" class="eas-filter-lang" value="en">
          <span>EN</span>
        </label>
        <label class="eas-mode-pill">
          <input type="radio" name="filter_langcode" class="eas-filter-lang" value="ar">
          <span>&#1593;&#1585;</span>
        </label>
      </div>
    </div>

    {# Media type toggle #}
    <div class="eas-filter-section">
      <h3 class="eas-filter-section__heading">{{ 'Media Type'|t }}</h3>
      <div class="eas-mode-pills eas-filter-media-pills">
        <label class="eas-mode-pill">
          <input type="radio" name="filter_media_type" class="eas-filter-media" value="all" checked>
          <span>{{ 'All'|t }}</span>
        </label>
        <label class="eas-mode-pill">
          <input type="radio" name="filter_media_type" class="eas-filter-media" value="docs_media">
          <span>{{ 'Documents & Media only'|t }}</span>
        </label>
      </div>
    </div>

    {# Clear filters #}
    <div class="eas-filter-footer">
      <button type="button" class="eas-filter-clear" id="eas-filter-clear">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
          <path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"/>
        </svg>
        {{ 'Clear all filters'|t }}
      </button>
    </div>

  </section>
  {# ── End filter panel ────────────────────────────────────────────────────── #}

  {% endif %}

  {# ── Did you mean ────────────────────────────────────────────────────────── #}
  <div id="search-did-you-mean" class="eas-dym" hidden></div>

  {# ── People also looking for ──────────────────────────────────────────────── #}
  <div id="search-related-queries" class="eas-related" hidden>
    <span class="eas-related__label">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
        <path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm0,160H40V56H216V200ZM184,96a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,96Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,128Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,160Z"/>
      </svg>
      {{ 'People also looking for'|t }}
    </span>
    <span class="related-chips eas-related__chips"></span>
  </div>

  {# ── Results ──────────────────────────────────────────────────────────────── #}
  <div id="search_results" class="eas-results" aria-live="polite" aria-atomic="false"></div>

</div>
