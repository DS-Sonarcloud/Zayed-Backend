<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>{{ subject }}</title>
  <style>
    body {
      font-family: 'Arial', sans-serif;
      background-color: #f8f9fa;
      color: #333;
      padding: 30px;
    }
    .email-container {
      max-width: 600px;
      margin: 0 auto;
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    .email-header {
      background-color: #004080;
      color: #fff;
      padding: 20px;
      text-align: center;
      font-size: 20px;
      font-weight: bold;
    }
    .email-body {
      padding: 25px;
      line-height: 1.6;
    }
    .email-footer {
      background-color: #f0f0f0;
      text-align: center;
      padding: 15px;
      font-size: 13px;
      color: #666;
    }
    .btn {
      display: inline-block;
      padding: 10px 20px;
      background-color: #004080;
      color: #fff !important;
      border-radius: 5px;
      text-decoration: none;
      margin-top: 15px;
    }
  </style>
</head>
<body>
  <div class="email-container">
    <div class="email-header">
      Zayed University Event Reminder
    </div>

    <div class="email-body">
      <p>Dear {{ username }},</p>

      <p>
        This is a friendly reminder that the event you're interested in is coming soon:
      </p>

      <h3>{{ event_title }}</h3>
      <p><strong>Date:</strong> {{ event_date }}</p>

      <p>
        You can view more details or join the event at:
        <br>
        <a class="btn" href="{{ event_link }}">View Event</a>
      </p>

      <p>We look forward to seeing you there!</p>

      <p>Best regards,<br>Zayed University Events Team</p>
    </div>

    <div class="email-footer">
      © {{ "now"|date("Y") }} Zayed University. All rights reserved.
    </div>
  </div>
</body>
</html>
