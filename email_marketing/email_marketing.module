/**
 * Custom submit handler to send emails.
 */
function email_marketing_send_test_email_submit(array &$form, FormStateInterface $form_state) {}

/**
 * AJAX callback for sending test email.
 */
function email_marketing_send_test_email_ajax_callback(array &$form, FormStateInterface $form_state)
{
  $response = ['#type' => 'container', '#attributes' => ['id' => 'test-email-status-wrapper']];

  $email = $form_state->getValue('test_email_address');
  if (empty($email) || !\Drupal::service('email.validator')->isValid($email)) {
    $response['#markup'] = '<div class="messages messages--error">' . t('Invalid email address.') . '</div>';
    return $response;
  }

  /** @var \Drupal\node\NodeInterface $node */
  $node = $form_state->getFormObject()->getEntity();
  $subject = $node->getTitle() ?: t('Test Email');

  $body = '';
  if ($node->hasField('field_template_image') && !$node->get('field_template_image')->isEmpty()) {
    /** @var \Drupal\file\FileInterface $file */
    $file = $node->get('field_template_image')->entity;
    $image_url = \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri());
    
    $body = '<div style="background-color: #f4f4f4; padding: 40px 0; text-align: center; font-family: Arial, sans-serif;">';
    $body .= '<div style="max-width: 100%; margin: 0 auto; background-color: #ffffff; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">';
    $body .= '<img src="' . $image_url . '" alt="' . $node->label() . '" style="width: 100%; max-width: 100%; height: auto; display: block;" />';
    $body .= '</div></div>';
  } else {
    $input = $form_state->getUserInput();
    $body = isset($input['body'][0]['value']) ? $input['body'][0]['value'] : '';
    if (empty($body)) {
      if ($node->hasField('body')) {
        $body = $node->get('body')->value;
      }
    }
    $body = make_absolute_image_urls($body);
  }

  // Send email immediately.
  $mailManager = \Drupal::service('plugin.manager.mail');
  $module = 'email_marketing';
  $key = 'test_email';
  $params = [
    'subject' => $subject,
    'message' => $body,
  ];
  $langcode = \Drupal::currentUser()->getPreferredLangcode();
  $send = TRUE;

  $result = $mailManager->mail($module, $key, $email, $langcode, $params, NULL, $send);

  if ($result['result']) {
    $response['#markup'] = '<div class="messages messages--status">' . t('Test email sent successfully to %email.', ['%email' => $email]) . '</div>';
  } else {
    $response['#markup'] = '<div class="messages messages--error">' . t('Failed to send test email to %email.', ['%email' => $email]) . '</div>';
  }

  return $response;
}

/**
 * Submit handler for sending emails to selected group.
 */
function email_marketing_send_to_group_submit(array &$form, FormStateInterface $form_state)
{
  /** @var \Drupal\node\NodeInterface $node */
  $node = $form_state->getFormObject()->getEntity();
  $input = $form_state->getUserInput();

  // Selected group entities from node input.
  $group_ids = $form_state->getValue('field_user_group_entity') ?? [];

  if (empty($group_ids)) {
    \Drupal::messenger()->addError(t('No groups selected.'));
    return;
  }

  // Collect all emails from those User Group entities.
  $emails = [];
  foreach ($group_ids as $item) {
    if (isset($item['target_id']) && $group = \Drupal\zu_user_group\Entity\UserGroup::load($item['target_id'])) {
      // Internal Users.
      foreach ($group->get('users')->referencedEntities() as $user) {
        if ($user instanceof User && $user->isActive() && $user->getEmail()) {
          $emails[$user->getEmail()] = $user->getEmail();
        }
      }
      // Public Users.
      foreach ($group->get('public_users')->referencedEntities() as $public_user) {
        if ($public_user instanceof \Drupal\zu_public_user\Entity\PublicUser && $public_user->getEmail()) {
          $emails[$public_user->getEmail()] = $public_user->getEmail();
        }
      }
    }
  }

  if (empty($emails)) {
    \Drupal::messenger()->addWarning(t('No emails found in the selected groups.'));
    return;
  }

  if (empty($users)) {
    \Drupal::messenger()->addWarning(t('No users found in this group.'));
    return;
  }

  // Subject from email template field.
  $email_node = Node::load($node->id());
  $subject = $email_node->getTitle();

  // Body from GrapesJS editor field.
  $input = $form_state->getUserInput();
  $body = $input['body'][0]['value'];
  $body = make_absolute_image_urls($body);


  // Mail manager service.
  $mailManager = \Drupal::service('plugin.manager.mail');
  $module = 'email_marketing';
  $key = 'user_groups_email';
  $langcode = \Drupal::currentUser()->getPreferredLangcode();

  foreach ($emails as $email) {
    $params['subject'] = $subject;
    $params['message'] = $body;

    $result = $mailManager->mail($module, $key, $email, $langcode, $params);
    if ($result['result'] !== TRUE) {
      \Drupal::messenger()->addError(t('Failed to send to %email.', ['%email' => $email]));
    } else {
      \Drupal::messenger()->addMessage(t('Email sent to %email.', ['%email' => $email]));
    }
  }
}

/**
 * Converts relative URLs in email body to absolute URLs.
 *
 */
function make_absolute_image_urls($body)
{
  if (empty($body)) {
    return $body;
  }
  $backend_url = \Drupal::request()->getSchemeAndHttpHost();
  $config = \Drupal::config('email_marketing.settings');
  $frontend_url = $config->get('frontend_base_url');

  // Convert all relative src and href attributes starting with /
  $body = preg_replace_callback(
    '/(\s(?:src|href)=["\'])(\/[^"\']+)(["\'])/i',
    function ($matches) use ($backend_url, $frontend_url) {
      $relative_path = $matches[2];
      if (preg_match('/^https?:\/\//i', $relative_path)) {
        return $matches[0];
      }
      // Use frontend URL for content pages, backend URL for file assets
      if ($frontend_url && !preg_match('#^/sites/|^/system/files/#', $relative_path)) {
        return $matches[1] . $frontend_url . $relative_path . $matches[3];
      }
      return $matches[1] . $backend_url . $relative_path . $matches[3];
    },
    $body
  );

  // Replace any absolute backend URLs in href with frontend URL 
  if ($frontend_url && $backend_url) {
    $body = preg_replace_callback(
      '/(\s(?:href)=["\'])(' . preg_quote($backend_url, '/') . ')(\/[^"\']+)(["\'])/i',
      function ($matches) use ($frontend_url, $backend_url) {
        $path = $matches[3];
        if (preg_match('#^/sites/|^/system/files/#', $path)) {
          return $matches[0];
        }
        return $matches[1] . $frontend_url . $path . $matches[4];
      },
      $body
    );
  }

  // Convert relative URLs in CSS background-image: url('/...')
  $body = preg_replace_callback(
    '/(url\(["\']?)(\/[^"\')\s]+)(["\']?\))/i',
    function ($matches) use ($backend_url) {
      return $matches[1] . $backend_url . $matches[2] . $matches[3];
    },
    $body
  );

  return $body;
}

