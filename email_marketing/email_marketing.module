/**
 * Implements hook_mail().
 */
function email_marketing_mail($key, &$message, $params)
{
  switch ($key) {
    case 'campaign':
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed';
      $message['subject'] = $params['subject'] ?? 'Newsletter';
      $message['body'][] = $params['body'] ?? '';
      break;

    case 'test_email':
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed';
      $message['subject'] = $params['subject'] ?? 'Newsletter';
      $message['body'][] = $params['message'] ?? '';
      break;

    case 'user_groups_email':
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed';
      $message['subject'] = $params['subject'] ?? 'Newsletter';
      $message['body'][] = $params['message'] ?? '';
      \Drupal::logger('bodyyyyyyyy')->debug('<pre>@data</pre>', [
        '@data' => print_r($message, TRUE),
      ]);
      break;

    case 'user_group_email':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['message'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed';
      break;
  }
}
/**
 * Implements hook_theme().
 */
function email_marketing_theme()
{
  return [
    'email_marketing_node' => [
      'variables' => [
        'subject' => NULL,
        'content' => NULL,
      ],
      'template' => 'email-marketing-node',
    ],
  ];
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function email_marketing_form_taxonomy_term_form_alter(&$form, FormStateInterface $form_state, $form_id)
{

  if (isset($form['field_user_members'])) {
    $form['csv_file'] = [
      '#type' => 'file',
      '#title' => t('Upload CSV File'),
      '#description' => t('Only CSV files are allowed.'),
      '#weight' => 7
    ];

    $form['preview'] = [
      '#type' => 'submit',
      '#value' => t('Preview'),
      '#submit' => ['previewCsv'],
      '#limit_validation_errors' => [],
      '#weight' => 8
    ];
  }
}

/**
 * Custom submit handler for preview button.
 */
function previewCsv(array &$form, FormStateInterface $form_state)
{
  if (!empty($_FILES['files']['tmp_name']['csv_file'])) {
    $tmp_file = $_FILES['files']['tmp_name']['csv_file'];
    $file_name = $_FILES['files']['name']['csv_file'];

    if (strtolower(pathinfo($file_name, PATHINFO_EXTENSION)) !== 'csv') {
      // $this->messenger()->addError('Only CSV files are allowed.');
      return;
    }

    // Read CSV
    if (($handle = fopen($tmp_file, 'r')) !== FALSE) {
      $emails = [];
      while (($data = fgetcsv($handle, 1000, ",")) !== FALSE) {
        $emails[] = $data[0];
      }
      fclose($handle);

      if (!empty($emails)) {
        // $this->messenger()->addMessage('<strong>CSV Preview:</strong>', ['html' => TRUE]);
        foreach ($emails as $email) {
          // Check if user exists.
          $existing = user_load_by_mail($email);

          if (!$existing) {
            $user = User::create([
              'name' => $email,
              'mail' => $email,
              'status' => 1,
              'roles' => ['manual_added_student'],
            ]);
            $user->enforceIsNew();
            $user->save();
          }
        }
        $form_state->set('csv_emails', $emails);
        $form_state->setRebuild(TRUE);
      } else {
        // $this->messenger()->addMessage('No data found in CSV.');
      }
    }
  }
}

/**
 * Implements hook_entity_presave().
 */
function email_marketing_entity_presave(EntityInterface $entity)
{
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'campaign') {
    $campaign_id = $entity->id();
    if (!$entity->get('field_email_template')->isEmpty()) {
      $target_id = $entity->get('field_email_template')->target_id;

      if ($target_id) {
        $template = Node::load($target_id);
        if ($template) {
          $existing = $template->get('field_campaign')->getValue();
          $existing_ids = array_column($existing, 'target_id');

          if (!in_array($campaign_id, $existing_ids)) {
            $existing[] = ['target_id' => $campaign_id];
            $template->set('field_campaign', $existing);
            $template->save();
          }
        }
      }
    }
  }
}

