/**
 * Update 9004: Add missing campaign_id to email_marketing_sent.
 */
function email_marketing_update_9004() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('email_marketing_sent') && !$schema->fieldExists('email_marketing_sent', 'campaign_id')) {
    $schema->addField('email_marketing_sent', 'campaign_id', [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'The related campaign ID.',
    ]);
  }
}

/**
 * Update 9005: Add resend_count column to email_marketing_sent.
 */
function email_marketing_update_9005() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('email_marketing_sent') && !$schema->fieldExists('email_marketing_sent', 'resend_count')) {
    $schema->addField('email_marketing_sent', 'resend_count', [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Number of times this campaign was resent.',
    ]);
  }
}

