// ── Config events ─────────────────────────────────────────────────────────────

/**
 * Implements hook_config_save().
 *
 * Records every configuration save except transient/noisy ones.
 */
function zu_admin_config_save(\Drupal\Core\Config\Config $config): void {
  // Skip high-frequency system configs that would flood the log.
  $skip_prefixes = ['system.cron', 'dblog.', 'update.', 'automated_cron.'];
  foreach ($skip_prefixes as $prefix) {
    if (str_starts_with($config->getName(), $prefix)) {
      return;
    }
  }
  if (!($audit = _zu_admin_audit())) return;
  $audit->log('config.save', 'Config saved: @name', ['@name' => $config->getName()]);
}

/**
 * Implements hook_config_delete().
 */
function zu_admin_config_delete(\Drupal\Core\Config\Config $config): void {
  if (!($audit = _zu_admin_audit())) return;
  $audit->log('config.delete', 'Config deleted: @name', ['@name' => $config->getName()]);
}

