// ── System events ─────────────────────────────────────────────────────────────

/**
 * Implements hook_modules_installed().
 */
function zu_admin_modules_installed(array $modules): void {
  if (!($audit = _zu_admin_audit())) return;
  $audit->log('system.module_enable', 'Modules enabled: @modules', [
    '@modules' => implode(', ', $modules),
  ]);
}

/**
 * Implements hook_modules_uninstalled().
 */
function zu_admin_modules_uninstalled(array $modules): void {
  if (!($audit = _zu_admin_audit())) return;
  $audit->log('system.module_disable', 'Modules uninstalled: @modules', [
    '@modules' => implode(', ', $modules),
  ]);
}
