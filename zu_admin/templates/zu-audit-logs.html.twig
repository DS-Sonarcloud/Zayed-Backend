{#
  Audit Logs page template.
  Variables:
    logs        — array of log row objects (timestamp, event_type, category, message, uid, username, ip_address)
    event_types — array of distinct event_type strings for the filter dropdown
    total       — total matching row count
    page        — current page number (1-based)
    total_pages — total pages
    page_size   — rows per page
    filters     — current filter values: event_type, uid, search, date_from, date_to
    base_params — filter params for building pagination URLs (without 'page')
    export_url  — URL for CSV download with current filters
#}
<div class="zu-audit-logs">

  {# ── Filter bar ─────────────────────────────────────────────────────────── #}
  <form method="get" action="" class="zu-audit-logs__filters">
    <div class="zu-audit-filters-row">

      <div class="zu-filter-group">
        <label for="audit-event-type">Category</label>
        <select id="audit-event-type" name="event_type">
          <option value="">— All events —</option>
          {% set categories = [] %}
          {% for et in event_types %}
            {% set cat = et|split('.')|first %}
            {% if cat not in categories %}
              {% set categories = categories|merge([cat]) %}
              <optgroup label="{{ cat|capitalize }}">
            {% endif %}
            <option value="{{ et }}"{% if filters.event_type == et %} selected{% endif %}>
              {{ et }}
            </option>
          {% endfor %}
          {% if event_types is not empty %}</optgroup>{% endif %}
        </select>
      </div>

      <div class="zu-filter-group">
        <label for="audit-search">Search message</label>
        <input id="audit-search" type="text" name="search"
               value="{{ filters.search|default('') }}"
               placeholder="keyword…">
      </div>

      <div class="zu-filter-group">
        <label for="audit-uid">User ID</label>
        <input id="audit-uid" type="number" name="uid" min="0"
               value="{{ filters.uid|default('') }}"
               placeholder="UID">
      </div>

      <div class="zu-filter-group">
        <label for="audit-date-from">From</label>
        <input id="audit-date-from" type="date" name="date_from"
               value="{{ filters.date_from|default('') }}">
      </div>

      <div class="zu-filter-group">
        <label for="audit-date-to">To</label>
        <input id="audit-date-to" type="date" name="date_to"
               value="{{ filters.date_to|default('') }}">
      </div>

      <div class="zu-filter-group zu-filter-actions">
        <button type="submit" class="button button--primary">Filter</button>
        <a href="?" class="button">Reset</a>
      </div>
    </div>
  </form>

  {# ── Summary bar ─────────────────────────────────────────────────────────── #}
  <div class="zu-audit-logs__summary">
    <span class="zu-audit-count">
      {{ total }} event{{ total != 1 ? 's' : '' }} found
      {% if total > page_size %}
        — showing {{ ((page - 1) * page_size + 1) }}–{{ [page * page_size, total]|min }}
      {% endif %}
    </span>
    {% if export_url %}
      <a href="{{ export_url }}" class="button button--small zu-audit-export">
        ⬇ Export CSV
      </a>
    {% endif %}
  </div>

  {# ── Table ───────────────────────────────────────────────────────────────── #}
  {% if logs is empty %}
    <p class="zu-audit-empty">No log entries match the current filters.</p>
  {% else %}
    <div class="zu-audit-logs__table-wrap">
      <table class="zu-audit-table">
        <thead>
          <tr>
            <th class="col-time">Timestamp</th>
            <th class="col-event">Event</th>
            <th class="col-user">User</th>
            <th class="col-message">Message</th>
            <th class="col-ip">IP Address</th>
          </tr>
        </thead>
        <tbody>
          {% for log in logs %}
            <tr class="audit-row audit-cat--{{ log.category }}">
              <td class="col-time">
                <span title="ID: {{ log.id }}">{{ log.timestamp }}</span>
              </td>
              <td class="col-event">
                <span class="audit-badge audit-badge--{{ log.category }}">
                  {{ log.event_type }}
                </span>
              </td>
              <td class="col-user">
                <span title="uid: {{ log.uid }}">
                  {{ log.username|default('uid:' ~ log.uid) }}
                </span>
              </td>
              <td class="col-message">{{ log.message }}</td>
              <td class="col-ip">{{ log.ip_address }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {# ── Pagination ──────────────────────────────────────────────────────────── #}
    {% if total_pages > 1 %}
      <nav class="zu-audit-pager" aria-label="Audit log pagination">
        {% if page > 1 %}
          <a href="?{{ base_params|merge({'page': page - 1})|url_encode }}"
             class="pager-btn" rel="prev">‹ Prev</a>
        {% endif %}

        {% for p in 1..total_pages %}
          {% if p == page %}
            <span class="pager-btn pager-btn--current">{{ p }}</span>
          {% elseif p == 1 or p == total_pages or (p >= page - 2 and p <= page + 2) %}
            <a href="?{{ base_params|merge({'page': p})|url_encode }}"
               class="pager-btn">{{ p }}</a>
          {% elseif p == page - 3 or p == page + 3 %}
            <span class="pager-ellipsis">…</span>
          {% endif %}
        {% endfor %}

        {% if page < total_pages %}
          <a href="?{{ base_params|merge({'page': page + 1})|url_encode }}"
             class="pager-btn" rel="next">Next ›</a>
        {% endif %}
      </nav>
    {% endif %}
  {% endif %}

</div>

<style>
.zu-audit-logs { font-family: system-ui, sans-serif; padding: 1rem; }
.zu-audit-filters-row { display: flex; flex-wrap: wrap; gap: .75rem; align-items: flex-end; background: #f4f6f8; padding: .75rem 1rem; border-radius: 6px; margin-bottom: 1rem; }
.zu-filter-group { display: flex; flex-direction: column; gap: .25rem; }
.zu-filter-group label { font-size: .75rem; font-weight: 600; color: #555; }
.zu-filter-group input, .zu-filter-group select { border: 1px solid #ccc; border-radius: 4px; padding: .35rem .6rem; font-size: .85rem; }
.zu-filter-actions { flex-direction: row; align-items: center; gap: .5rem; }
.zu-audit-logs__summary { display: flex; justify-content: space-between; align-items: center; margin-bottom: .75rem; font-size: .85rem; color: #555; }
.zu-audit-export { font-size: .8rem; }
.zu-audit-table { width: 100%; border-collapse: collapse; font-size: .83rem; }
.zu-audit-table th { background: #2a3f5f; color: #fff; padding: .5rem .75rem; text-align: left; white-space: nowrap; }
.zu-audit-table td { padding: .45rem .75rem; border-bottom: 1px solid #eee; vertical-align: top; }
.zu-audit-table tbody tr:hover { background: #f0f4ff; }
.col-time { white-space: nowrap; width: 145px; color: #555; }
.col-event { width: 160px; }
.col-user { width: 120px; }
.col-ip { width: 110px; font-family: monospace; font-size: .78rem; color: #777; }
.col-message { word-break: break-word; }
.audit-badge { display: inline-block; padding: .15rem .5rem; border-radius: 3px; font-size: .75rem; font-weight: 600; }
.audit-badge--node { background: #dbeafe; color: #1d4ed8; }
.audit-badge--user { background: #dcfce7; color: #15803d; }
.audit-badge--taxonomy { background: #fef9c3; color: #854d0e; }
.audit-badge--media { background: #fce7f3; color: #9d174d; }
.audit-badge--config { background: #f3e8ff; color: #7e22ce; }
.audit-badge--file { background: #ffedd5; color: #9a3412; }
.audit-badge--comment { background: #e0f2fe; color: #0369a1; }
.audit-badge--system { background: #f1f5f9; color: #475569; }
.audit-badge--webform { background: #ecfdf5; color: #065f46; }
.zu-audit-empty { color: #777; font-style: italic; padding: 1rem 0; }
.zu-audit-pager { display: flex; gap: .35rem; align-items: center; margin-top: 1rem; flex-wrap: wrap; }
.pager-btn { padding: .3rem .65rem; border: 1px solid #ccc; border-radius: 4px; text-decoration: none; color: #333; font-size: .82rem; }
.pager-btn--current { background: #2a3f5f; color: #fff; border-color: #2a3f5f; font-weight: 700; }
.pager-btn:hover:not(.pager-btn--current) { background: #e8edf5; }
.pager-ellipsis { padding: .3rem .4rem; color: #999; }
</style>
