{#
/**
 * @file
 * Default theme implementation for the ZU Admin Workflows List.
 */
#}
<div class="zu-admin-shell">
  {% include '@zu_admin/zu-admin-topbar.html.twig' %}

  <div class="zu-body-wrap">
    {% include '@zu_admin/zu-admin-sidebar.html.twig' with {
      sidebar: sidebar,
      user_info: user_info,
    } only %}
    
    <main class="zu-main-content">
      <div class="zu-breadcrumb">
        <a href="/zu-admin/dashboard" class="zu-breadcrumb-link">{{ 'Home'|t }}</a>
        <span class="zu-breadcrumb-sep">›</span>
        <span class="zu-breadcrumb-current">{{ group_name }}</span>
      </div>

      <div class="zu-page-header">
        <h1 class="zu-page-heading">{{ group_name }}</h1>
      </div>

      <div class="zu-tabs">
        {% for id, tab in tabs %}
          <a href="{{ tab.url }}" class="zu-tab {% if active_tab == id %}is-active{% endif %}">{{ tab.title }}</a>
        {% endfor %}
      </div>

      <div class="zu-workflows-table-wrap">
        <table class="zu-table">
          <thead>
            <tr>
              <th>{{ 'Name'|t }}</th>
              <th>{{ 'Workflow Owner'|t }}</th>
              <th>{{ 'Step Owner'|t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for workflow in workflows %}
              <tr>
                <td><span class="zu-workflow-icon">🕒</span><a href="#" class="zu-workflow-link">{{ workflow.label }}</a></td>
                <td><span class="zu-owner-icon">👤</span>{{ workflow.owner }}</td>
                <td><span class="zu-owner-icon">👤</span>{{ workflow.step_owner }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </main>
  </div>
</div>
