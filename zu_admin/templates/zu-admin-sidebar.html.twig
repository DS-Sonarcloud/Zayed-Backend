{#
/**
 * @file
 * ZU Admin sidebar navigation.
 */
#}
<aside class="zu-sidebar">
  <div class="zu-sidebar-logo">
    <a href="{{ path('zu_admin.dashboard') }}">
      <span class="zu-logo-fallback">ZU</span>
    </a>
  </div>

  <nav class="zu-sidebar-nav" aria-label="{{ 'ZU Admin'|t }}">
    {% if sidebar %}
      {% for item in sidebar %}
        <a href="{{ item.url }}" class="zu-nav-item{% if item.active %} is-active{% endif %}">
          <span class="zu-nav-icon">{{ item.icon_svg|raw }}</span>
          <span class="zu-nav-label">{{ item.label }}</span>
          {% if item.badge > 0 %}
            <span class="zu-nav-badge">{{ item.badge }}</span>
          {% endif %}
        </a>
      {% endfor %}
    {% else %}
      <a href="{{ path('zu_admin.dashboard') }}" class="zu-nav-item is-active">
        <span class="zu-nav-label">{{ 'Dashboard'|t }}</span>
      </a>
    {% endif %}
  </nav>

  <div class="zu-sidebar-footer">
    <div class="zu-user-profile">
      <div class="zu-user-avatar">
        <span class="zu-avatar-initials">{{ user_info.initials|default(user_info.name|first|upper) }}</span>
      </div>
      <div class="zu-user-info">
        <span class="zu-user-name">{{ user_info.name|default('User'|t) }}</span>
        <span class="zu-user-role">{{ user_info.role|default('') }}</span>
      </div>
    </div>
    <div class="zu-sidebar-actions">
      <button type="button" class="zu-icon-btn" title="{{ 'Settings'|t }}">⚙</button>
      <button type="button" class="zu-icon-btn" title="{{ 'Help'|t }}">?</button>
    </div>
  </div>
</aside>
