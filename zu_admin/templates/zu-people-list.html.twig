{#
/**
 * @file
 * Default theme implementation for the ZU Admin People List.
 */
#}
<div class="zu-admin-shell">
  {% include '@zu_admin/zu-admin-topbar.html.twig' %}

  <div class="zu-body-wrap">
    {% include '@zu_admin/zu-admin-sidebar.html.twig' with {
      sidebar: sidebar,
      user_info: user_info,
    } only %}
    
    <main class="zu-main-content">
      <div class="zu-breadcrumb">
        <a href="/zu-admin/dashboard" class="zu-breadcrumb-link">{{ 'Home'|t }}</a>
        <span class="zu-breadcrumb-sep">›</span>
        <span class="zu-breadcrumb-current">{{ 'People'|t }}</span>
      </div>

      <div class="zu-page-header">
        <h1 class="zu-page-heading">{{ 'People'|t }}</h1>
      </div>

      <div class="zu-tabs">
        {% for id, tab in tabs %}
          <a href="{{ tab.url }}" class="zu-tab {% if active_tab == id %}is-active{% endif %}">{{ tab.title }}</a>
        {% endfor %}
      </div>

      <div class="zu-section-card">
        <h2 class="zu-card-title">{{ 'Users'|t }}</h2>
        <table class="zu-table">
          <thead>
            <tr>
              <th>{{ 'Name'|t }}</th>
              <th>{{ 'Roles'|t }}</th>
              <th>{{ 'Operations'|t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for user in users %}
              <tr>
                <td>{{ user.getDisplayName() }}</td>
                <td>{{ user.getRoles()|join(', ') }}</td>
                <td><a href="/zu-admin/people/{{ user.id() }}/view">{{ 'View'|t }}</a></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </main>
  </div>
</div>
