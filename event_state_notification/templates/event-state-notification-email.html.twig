<!DOCTYPE html>
<html>
  <body style="font-family: Arial, sans-serif; color: #333; line-height: 1.6;">

    <p>Hello {{ user }},</p>

    {% if notification_message %}
      <p>{{ notification_message|raw }}</p>
    {% else %}
      <p>
        The event <strong>"{{ title }}"</strong> has changed moderation status.
      </p>
    {% endif %}

    <table style="border-collapse: collapse; margin: 10px 0;">
      <tr>
        <td style="padding: 6px 12px; border: 1px solid #ccc;">Previous State</td>
        <td style="padding: 6px 12px; border: 1px solid #ccc;">{{ old_state }}</td>
      </tr>
      <tr>
        <td style="padding: 6px 12px; border: 1px solid #ccc;">New State</td>
        <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: bold;">{{ new_state }}</td>
      </tr>
    </table>

    <p>
      You may review the event here:  
      <a href="{{ link }}" style="color: #0073e6;">{{ link }}</a>
    </p>

    <p style="margin-top: 20px;">
      Thank you,<br>
      <strong>Your Content Moderation Team</strong>
    </p>
  </body>
</html>
