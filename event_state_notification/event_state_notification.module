function event_state_notification_theme() {
  return [
    'event_state_notification_email' => [
      'variables' => [
        'title' => NULL,
        'old_state' => NULL,
        'new_state' => NULL,
        'link' => NULL,
        'user' => NULL,
        'notification_message' => NULL,
      ],
      'template' => 'event-state-notification-email',
    ],
  ];
}

function event_state_notification_form_alter(array &$form, FormStateInterface $form_state, $form_id)
{

  if (!\Drupal::currentUser()->hasRole('administrator')) {
    return;
  }

  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return;
  }
  $entity = $form_object->getEntity();
  if (!$entity || $entity->getEntityTypeId() !== 'node') {
    return;
  }

  if (!$entity->hasField('moderation_state')) {
    return;
  }

  $moderation_info = \Drupal::service('content_moderation.moderation_information');
  $workflow = $moderation_info->getWorkflowForEntity($entity);

  if (!$workflow || $workflow->id() !== 'events_work_flow') {
    return;
  }

  $states = [];
  foreach ($workflow->getTypePlugin()->getStates() as $id => $state) {
    $states[$id] = $state->label();
  }

  if (isset($form['moderation_state']['widget'][0]['state'])) {
    $el = &$form['moderation_state']['widget'][0]['state'];
    $el['#type'] = 'select';
    $el['#options'] = $states;
    $el['#element_validate'] = [];
  }

  foreach (['publish_state', 'state', 'moderation_state', 'publish'] as $key) {
    if (isset($form['actions'][$key])) {
      $el = &$form['actions'][$key];
      $el['#type'] = 'select';
      $el['#options'] = $states;
      $el['#element_validate'] = [];
    }
  }
}
