<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\node\NodeInterface;
use Drupal\Core\Access\AccessResult;
use Drupal\Core\Mail\MailFormatHelper;
use Drupal\Core\Render\RendererInterface;
use Drupal\Core\Form\FormStateInterface;


/**
 * Implements hook_help().
 */
function event_state_notification_help($route_name)
{
  switch ($route_name) {
    case 'help.page.event_state_notification':
      return t('This module sends email notifications when an event changes its moderation state.');
  }
}

/**
 * Implements hook_mail().
 */
function event_state_notification_mail($key, &$message, $params)
{
  switch ($key) {
    case 'state_change_notification':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['body'];

      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
      $message['headers']['MIME-Version'] = '1.0';
      break;
  }
}

/**
 * Implements hook_entity_presave().
 */
function event_state_notification_entity_presave(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'node' || !$entity->hasField('moderation_state')) {
    return;
  }

  $current_user_entity = \Drupal::entityTypeManager()->getStorage('user')->load(\Drupal::currentUser()->id());

  $new_state = $entity->get('moderation_state')->value;
  // Handle existing or new entities
  $old_state = (isset($entity->original)) ? $entity->original->get('moderation_state')->value : NULL;

  if (!$entity->isNew() && $old_state === $new_state && $new_state !== 'draft') {
    return;
  }

  // Define logic for notifications
  $notifications = [];
  $title = $entity->label();
  
  // Helper to standardise notification task structure
  // task = ['roles' => [], 'users' => [], 'subject' => '', 'message' => '']

  switch ($new_state) {
    case 'need_review':
    case 'needs_review':
      if ($old_state === 'draft' || $entity->isNew()) {
        $notifications[] = [
          'target_permission' => 'edit any department content',
          'subject' => "New content ready for review: $title",
          'message' => "New content <strong>$title</strong> is ready for review.",
        ];
      }
      break;

    case 'published':
      if ($old_state === 'need_review' || $old_state === 'needs_review') {
        $owner = $entity->getOwner();
        if ($owner) {
          $notifications[] = [
            'users' => [$owner],
            'subject' => "Content published: $title",
            'message' => "Your content <strong>$title</strong> has been published.",
          ];
        }
      }
      break;

    case 'draft':
      if ($old_state === 'published') {
        $owner = $entity->getOwner();
        if ($owner) {
          $notifications[] = [
            'users' => [$owner],
            'subject' => "Content moved to draft: $title",
            'message' => "Your published content <strong>$title</strong> has been moved back to draft.",
          ];
        }
      }
      break;
  }

  if (empty($notifications)) {
    return;
  }

  // Store notifications in entity for processing after save
  $entity->_event_notifications = [
    'notifications' => $notifications,
    'old_state' => $old_state,
    'new_state' => $new_state,
  ];
}

/**
 * Implements hook_entity_insert().
 */
function event_state_notification_entity_insert(EntityInterface $entity) {
  event_state_notification_send_emails($entity);
}

/**
 * Implements hook_entity_update().
 */
function event_state_notification_entity_update(EntityInterface $entity) {
  event_state_notification_send_emails($entity);
}

/**
 * Helper function to send notification emails.
 */
function event_state_notification_send_emails(EntityInterface $entity) {
  // Check if we have pending notifications
  if (!isset($entity->_event_notifications)) {
    return;
  }

  $notification_data = $entity->_event_notifications;
  $notifications = $notification_data['notifications'];
  $old_state = $notification_data['old_state'];
  $new_state = $notification_data['new_state'];
  $title = $entity->label();

  // Now we can safely get the URL since entity has been saved
  $url = $entity->toUrl('canonical', ['absolute' => TRUE])->toString();
  $renderer = \Drupal::service('renderer');
  $mail_manager = \Drupal::service('plugin.manager.mail');
  $langcode = \Drupal::languageManager()->getDefaultLanguage()->getId();

  foreach ($notifications as $task) {
    $recipients = [];

    // Load candidate users by permission
    $candidate_users = [];
    if (!empty($task['target_permission'])) {
      $permission = $task['target_permission'];
      $roles_with_permission = [];
      foreach (\Drupal\user\Entity\Role::loadMultiple() as $role) {
        if ($role->hasPermission($permission)) {
          $roles_with_permission[] = $role->id();
        }
      }

      if (!empty($roles_with_permission)) {
        $candidate_users = \Drupal::entityTypeManager()->getStorage('user')->loadByProperties(['roles' => $roles_with_permission]);
      }
    } elseif (!empty($task['roles'])) {
      $candidate_users = \Drupal::entityTypeManager()->getStorage('user')->loadByProperties(['roles' => $task['roles']]);
    }

    if (!empty($candidate_users)) {
      $target_depts = [];
      
      // Check if the Entity itself has a department
      if ($entity->hasField('field_event_type') && !$entity->get('field_event_type')->isEmpty()) {
        foreach ($entity->get('field_event_type') as $item) {
          $target_depts[] = $item->target_id;
        }
      }
      // Fallback to Author departments (if entity has no dept)
      else {
        $owner = $entity->getOwner();
        if ($owner && $owner->hasField('field_event_department')) {
          foreach ($owner->get('field_event_department') as $item) {
            $target_depts[] = $item->target_id;
          }
        }
      }

      foreach ($candidate_users as $u) {
        $is_match = FALSE;
        if (empty($target_depts) || $u->hasRole('administrator')) {
          $is_match = TRUE;
        } else {
          if ($u->hasField('field_event_department')) {
            foreach ($u->get('field_event_department') as $item) {
              if (in_array($item->target_id, $target_depts)) {
                $is_match = TRUE;
                break;
              }
            }
          }
        }

        if ($is_match) {
          $recipients[] = $u;
        }
      }
    }

    
    // Add explicit users
    if (!empty($task['users'])) {
      $recipients = array_merge($recipients, $task['users']);
    }

    // Deduplicate by ID
    $unique_recipients = [];
    foreach ($recipients as $u) {
      if ($u && $u->id()) { // check if user object is valid
         $unique_recipients[$u->id()] = $u;
      }
    }

    foreach ($unique_recipients as $user) {
      if (!$email = $user->getEmail()) {
        continue;
      }

      $build = [
        '#theme' => 'event_state_notification_email',
        '#title' => $title,
        '#old_state' => $old_state,
        '#new_state' => $new_state,
        '#link' => $url,
        '#user' => $user->getDisplayName(),
        '#notification_message' => $task['message'],
      ];

      $body = $renderer->renderPlain($build);

      $params = [
        'subject' => $task['subject'],
        'body' => $body,
      ];

      $mail_manager->mail(
        'event_state_notification',
        'state_change_notification',
        $email,
        $langcode,
        $params
      );
    }
  }

  // Clean up
  unset($entity->_event_notifications);
}


