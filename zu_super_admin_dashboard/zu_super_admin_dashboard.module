<?php

/**
 * @file
 * ZU Super Admin Dashboard — central overview for platform super administrators.
 */

use Drupal\Core\Url;
use Drupal\user\Entity\Role;
use Drupal\zu_super_admin_dashboard\ContentDashboardRoutes;

/**
 * Implements hook_theme().
 *
 * Template is overridden by claro_admin/templates/zu-super-admin-dashboard.html.twig.
 */
function zu_super_admin_dashboard_theme(array $existing, string $type, string $theme, string $path): array {
  return [
    'zu_super_admin_dashboard' => [
      'variables' => [
        'welcome' => [],
        'alerts' => [],
        'advanced_search' => NULL,
        'actions' => [],
        'dashboard_menu' => ['title' => '', 'links' => []],
        'deploy_menu' => ['title' => '', 'links' => []],
        'platform_ops' => [],
        'permission_matrix' => [],
        'appearance_settings' => [],
        'public_users' => [],
        'search' => [],
        'actions_more' => NULL,
        'platform_more' => NULL,
        'permission_more' => NULL,
        'appearance_more' => NULL,
        'public_users_more' => NULL,
        'search_more' => NULL,
        'dashboard_more' => NULL,
        'recent_more' => NULL,
        'erd_more' => NULL,
        'erd' => [
          'categories' => [],
          'schema' => ['branch' => '', 'ready' => FALSE, 'tables_expected' => 0, 'tables_installed' => 0, 'marker_tables' => []],
          'totals' => [],
        ],
        'recent_content' => [],
        'section_nav' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_page().
 *
 * Drupal injects status_messages into page.content when the messages block
 * is disabled (see BlockPageVariant). Clear those and the messenger queue so
 * admin banners (security update, cache cleared, etc.) do not appear here.
 */
function zu_super_admin_dashboard_preprocess_page(array &$variables): void {
  if (\Drupal::routeMatch()->getRouteName() !== 'zu_super_admin_dashboard.dashboard') {
    return;
  }

  \Drupal::messenger()->deleteAll();

  foreach (['pre_content', 'highlighted', 'help'] as $region) {
    $variables['page'][$region] = [];
  }

  if (!isset($variables['page']['content']) || !is_array($variables['page']['content'])) {
    return;
  }

  unset($variables['page']['content']['messages']);
  foreach ($variables['page']['content'] as $key => $child) {
    if (is_array($child) && ($child['#type'] ?? NULL) === 'status_messages') {
      unset($variables['page']['content'][$key]);
    }
  }
}

/**
 * Implements hook_zu_app_navigation_alter().
 *
 * Adds one "Dashboards" item with level-2 flyout links for content Views.
 *
 * @param list<array<string, mixed>> $items
 */
function zu_super_admin_dashboard_zu_app_navigation_alter(array &$items): void {
  $children = zu_super_admin_dashboard_content_dashboard_nav_children();
  if ($children === []) {
    return;
  }

  $group_active = FALSE;
  foreach ($children as $child) {
    if (!empty($child['active'])) {
      $group_active = TRUE;
      break;
    }
  }

  $group = [
    'label' => (string) t('Dashboards'),
    'route' => 'zu_super_admin_dashboard.content_dashboards',
    'icon' => '📊',
    'active' => $group_active,
    'children' => $children,
  ];

  $offset = 0;
  foreach ($items as $index => $item) {
    if (($item['route'] ?? '') === 'zu_super_admin_dashboard.dashboard') {
      $offset = $index + 1;
      break;
    }
  }
  array_splice($items, $offset, 0, [$group]);
}

/**
 * Builds flyout child links for content dashboard Views.
 *
 * @return list<array{label: string, url: string, route: string, icon: string, active: bool}>
 */
function zu_super_admin_dashboard_content_dashboard_nav_children(): array {
  $account = \Drupal::currentUser();
  $current = \Drupal::routeMatch()->getRouteName() ?? '';
  $access_manager = \Drupal::accessManager();

  $dashboards = [
    [
      'label' => (string) t('Events'),
      'route' => 'view.event_dashboard.event_dashboard_page',
      'icon' => '📅',
    ],
    [
      'label' => (string) t('Blogs'),
      'route' => 'view.blog_listing.blog_dashboard',
      'icon' => '📝',
    ],
    [
      'label' => (string) t('News'),
      'route' => 'view.news_api.news_dashboard',
      'icon' => '📰',
    ],
    [
      'label' => (string) t('Faculty'),
      'route' => 'view.faculty.faculty_staff_dashboard',
      'icon' => '🎓',
    ],
    [
      'label' => (string) t('Jobs'),
      'route' => 'view.jobs_listing.page_1',
      'icon' => '💼',
    ],
  ];

  $children = [];
  foreach ($dashboards as $dashboard) {
    if (!in_array($dashboard['route'], ContentDashboardRoutes::ROUTES, TRUE)) {
      continue;
    }
    if (!$access_manager->checkNamedRoute($dashboard['route'], [], $account)) {
      continue;
    }
    try {
      $url = Url::fromRoute($dashboard['route'])->toString();
    }
    catch (\Exception) {
      continue;
    }
    $children[] = [
      'label' => $dashboard['label'],
      'url' => $url,
      'route' => $dashboard['route'],
      'icon' => $dashboard['icon'],
      'active' => $current === $dashboard['route'],
    ];
  }

  return $children;
}

/**
 * Implements hook_install().
 */
function zu_super_admin_dashboard_install(): void {
  $permission = 'access zu super admin dashboard';
  foreach (['super_admin'] as $role_id) {
    $role = Role::load($role_id);
    if ($role && !$role->hasPermission($permission)) {
      $role->grantPermission($permission);
      $role->save();
    }
  }
}
