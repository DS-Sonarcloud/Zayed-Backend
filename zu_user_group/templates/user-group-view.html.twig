{% set v = variables %}


{% if v.author %}
  <div class="user-group-view-section">
    <h2>{{ 'Authored by'|t }}</h2>
    <div class="author-details">
      <span class="author-label">{{ 'User:'|t }}</span>
      {# <span class="author-name">{{ v.author.link|raw }}</span> #}
      <span class="author-name">{{ v.author.link|raw }}</span>
      {% if v.author.email %}
        <span class="author-email">({{ v.author.email }})</span>
      {% endif %}
    </div>
  </div>
{% endif %}

{% if v.target_roles is not empty %}
  <div class="user-group-view-section">
    <h2>{{ 'Internal Roles'|t }}</h2>
    <div class="roles-grid">
      {% for role in v.target_roles %}
        <div class="role-card">
          <span class="role-name">{{ role.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% if v.target_webforms is not empty %}
  <div class="user-group-view-section">
    <h2>{{ 'Target Webforms'|t }}</h2>
    <ul class="webform-list">
      {% for webform in v.target_webforms %}
        <li>{{ webform.link|raw }}</li>
      {% endfor %}
    </ul>
  </div>
{% endif %}

{% if not v.target_all_public_users %}
  {% if v.public_segments is not empty %}
    <div class="user-group-view-section">
      <h2>{{ 'Public Subscribers'|t }}</h2>
      <ul class="segment-list">
        {% for segment in v.public_segments %}
          <li>{{ segment }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  {% if v.event_types is not empty %}
    <div class="user-group-view-section">
      <h2>{{ 'Event Categories'|t }}</h2>
      <ul class="event-list">
        {% for event in v.event_types %}
          <li>{{ event }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
{% endif %}

{% if v.target_all_public_users %}
  <div class="user-group-view-section broadcast">
    <h2>{{ 'Public User'|t }}</h2>
    <p class="broadcast-text">{{ 'Targeting ALL active public users'|t }}</p>
  </div>
{% endif %}

{% if v.campaigns is not empty %}
  <div class="user-group-view-section">
    <h2>{{ 'Campaign Usage'|t }}</h2>
    <ul class="campaign-list">
      {% for campaign in v.campaigns %}
        <li>
          {{ campaign.link }}
          <span class="status {{ campaign.status }}">{{ campaign.status_label }}</span>
        </li>
      {% endfor %}
    </ul>
  </div>
{% else %}
  <div class="user-group-view-section">
    <h2>{{ 'Campaign Usage'|t }}</h2>
    <p class="empty-state">{{ 'Not currently used in any campaigns'|t }}</p>
  </div>
{% endif %}
