<!DOCTYPE html>
<html lang="en">
  <head><title>Event Subscription Confirmation</title></head>
  <body style="font-family: Arial, sans-serif;">
    <p>Hello {{ name }},</p>

    <p>You have successfully subscribed to the following event categories:</p>

    <ul>
      {% for t in terms %}
        <li>{{ t }}</li>
      {% endfor %}
    </ul>

    <p>Thank you for staying connected!</p>
  </body>
</html>
