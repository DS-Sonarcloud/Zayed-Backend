<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>{{ subject }}</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f8f9fa;
      padding: 20px;
    }
    .container {
      max-width: 650px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 8px;
      padding: 25px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.06);
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .header img {
      max-height: 50px;
    }
    .title {
      font-size: 22px;
      color: #333;
      font-weight: bold;
      margin-bottom: 15px;
      text-align: center;
    }
    .content {
      font-size: 15px;
      color: #444;
      line-height: 1.6;
    }
    .footer {
      margin-top: 35px;
      font-size: 13px;
      color: #777;
      text-align: center;
    }
    .highlight {
      font-weight: bold;
      color: #c81d72;
    }
  </style>
</head>
<body>

<div class="container">

  <div class="header">
    {% if brand_logo %}
      <img src="{{ brand_logo }}" alt="{{ brand_name }}">
    {% endif %}
  </div>

  <div class="title">
    {{ subject }}
  </div>

  <div class="content">
    <p>Hi <strong>{{ user_name }}</strong>,</p>

    <p>
      Thank you for subscribing to our <strong>Blogs updates</strong>!
      You will now receive the latest updates directly in your inbox.
    </p>

    {% if temp_password %}
      <p>
        Your temporary password is:
        <span class="highlight">{{ temp_password }}</span>
      </p>
    {% endif %}

    <p>
      If you did not subscribe, please contact us at:
      <br>
      <strong>{{ support_email }}</strong>
    </p>
  </div>

  <div class="footer">
    — The {{ brand_name }} Team
  </div>

</div>

</body>
</html>
