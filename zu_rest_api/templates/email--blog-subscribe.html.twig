<!DOCTYPE html>
<html>
  <body style="font-family: Arial, sans-serif; color: #333;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="border:1px solid #ddd; border-radius:8px;">
            <tr style="background:#0ea5a4;">
              <td style="padding:20px; text-align:center; color:white;">
                <img src="{{ brand_logo }}" alt="{{ brand_name }}" width="120" />
                <h2 style="margin-top:10px;">{{ brand_name }}</h2>
              </td>
            </tr>
            <tr>
              <td style="padding:20px;">
                <h3>Hello {{ user_name }}</h3>
                <p>Thank you for subscribing to <strong>{{ brand_name }}</strong>.</p>
                <p>You’ll now receive updates about blogs and events!</p>
                <p style="margin-top:30px;">
                  <a href="{{ manage_url }}" style="background:#0ea5a4; color:#fff; padding:10px 18px; border-radius:6px; text-decoration:none;">Manage Preferences</a>
                </p>
                <p style="margin-top:20px; font-size:12px; color:#777;">If you have any questions, contact <a href="mailto:{{ support_email }}">{{ support_email }}</a>.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
