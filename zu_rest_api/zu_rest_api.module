function zu_rest_api_form_node_organizer_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  unset($form['menu']);

  unset($form['path']);

  unset($form['revision_information']);

  unset($form['short_alias']);
}

/**
 * Implements hook_form_BASE_ID_alter().
 */
function zu_rest_api_form_node_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $node = $form_state->getFormObject()->getEntity();
  
  if ($node->bundle() === 'news') {
    $form['#validate'][] = 'zu_rest_api_news_date_validate';
  }

  if (in_array($node->bundle(), ['event', 'email_template'])) {
    foreach (array_keys($form['actions']) as $action) {
      if ($action !== 'preview' && isset($form['actions'][$action]['#type']) && $form['actions'][$action]['#type'] === 'submit') {
        $form['actions'][$action]['#submit'][] = 'zu_rest_api_node_form_redirect_submit';
      }
    }
  }
}

/**
 * Custom submit handler to redirect back to dashboard if node is unpublished.
 */
function zu_rest_api_node_form_redirect_submit($form, FormStateInterface $form_state) {
  $node = $form_state->getFormObject()->getEntity();
  if (!$node->isPublished()) {
    $bundle = $node->bundle();
    $url = ($bundle === 'event') ? '/event-dashboard' : '/email-templates';
    $form_state->setRedirectUrl(\Drupal\Core\Url::fromUserInput($url));
  }
}


/**
 * Implements hook_page_attachments().
 */
function zu_rest_api_page_attachments(array &$attachments)
{
  $attachments['#attached']['library'][] = 'zu_rest_api/admin_styles';
  $attachments['#attached']['library'][] = 'zu_rest_api/admin_scripts';
}

/**
 * Implements hook_mail().
 */
function zu_rest_api_mail($key, &$message, $params)
{
  switch ($key) {
    case 'blog_new_notification':
      $message['subject'] = $params['subject'];
      $message['body'] = $params['body'];
      $message['headers'] = $params['headers'];
      break;

    case 'subscriber_created':
      $message['subject'] = $params['subject'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
      $message['body'][] = \Drupal::theme()->render('zu_subscriber_created_email', [
        'name' => $params['name'],
        'password' => $params['password'],
      ]);
      break;

    case 'newsletter_subscribe':
      $message['subject'] = $params['subject'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

      $build = [
        '#theme' => 'zu_newsletter_subscribe_email',
        '#name' => $params['name'],
      ];

      $body = \Drupal::service('renderer')->renderPlain($build);
      $message['body'][] = $body;
      break;


    case 'newsletter_unsubscribe':
      $message['subject'] = $params['subject'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
      $message['body'][] = \Drupal::theme()->render('zu_newsletter_unsubscribe_email', [
        'name' => $params['name'],
      ]);
      break;

    case 'blog_subscribe_confirmation':
      $message['subject'] = $params['subject'];

      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
      $message['headers']['MIME-Version'] = '1.0';

      $message['body'][] = [
        '#theme' => 'blog_subscribe_confirmation',
        '#subject' => $params['subject'],
        '#user_name' => $params['user_name'],
        '#brand_name' => $params['brand_name'],
        '#brand_logo' => $params['brand_logo'],
        '#manage_url' => $params['manage_url'],
        '#support_email' => $params['support_email'],
        '#temp_password' => $params['temp_password'] ?? NULL,
      ];
    case 'blog_subscribe_confirmation':
      $message['subject'] = $params['subject'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

      $build = [
        '#theme' => 'blog_subscribe_confirmation',
        '#subject' => $params['subject'],
        '#user_name' => $params['user_name'],
        '#brand_name' => $params['brand_name'],
        '#brand_logo' => $params['brand_logo'],
        '#manage_url' => $params['manage_url'],
        '#support_email' => $params['support_email'],
        '#temp_password' => $params['temp_password'] ?? NULL,
      ];
      $message['body'][] = \Drupal::service('renderer')->renderPlain($build);
      break;

    case 'news_subscribe_confirmation':
      $message['subject'] = $params['subject'];

      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
      $message['headers']['MIME-Version'] = '1.0';

      $message['body'][] = [
        '#theme' => 'news_subscribe_confirmation',
        '#subject' => $params['subject'],
        '#user_name' => $params['user_name'],
        '#brand_name' => $params['brand_name'],
        '#brand_logo' => $params['brand_logo'],
        '#manage_url' => $params['manage_url'],
        '#support_email' => $params['support_email'],
        '#temp_password' => $params['temp_password'] ?? NULL,
      ];
    case 'news_subscribe_confirmation':
      $message['subject'] = $params['subject'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

      $build = [
        '#theme' => 'news_subscribe_confirmation',
        '#subject' => $params['subject'],
        '#user_name' => $params['user_name'],
        '#brand_name' => $params['brand_name'],
        '#brand_logo' => $params['brand_logo'],
        '#manage_url' => $params['manage_url'],
        '#support_email' => $params['support_email'],
        '#temp_password' => $params['temp_password'] ?? NULL,
      ];
      $message['body'][] = \Drupal::service('renderer')->renderPlain($build);
      break;

    case 'event_subscribe':
      $message['subject'] = $params['subject'];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

      $message['body'][] = \Drupal::theme()->render('zu_event_subscribe_email', [
        'name' => $params['name'],
        'terms' => $params['terms'],
      ]);
      break;
  }
}

/**
 * Helper: whether the layout builder "deploy" toggle is enabled for a node.
 */
function _zu_rest_api_is_layoutbuilder_deploy_enabled($nid) {
  try {
    $connection = \Drupal::database();
    $result = $connection->query("SELECT data FROM drupal_layoutbuilder_data WHERE uid = :nid ORDER BY ID DESC LIMIT 1", [':nid' => $nid])
      ->fetch();

    if ($result && !empty($result->data)) {
      $data = json_decode($result->data, true);
      if (isset($data['settings']['deploy']) && $data['settings']['deploy'] === 'yes') {
        return TRUE;
      }
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('zu_rest_api')->error('Error checking layout builder deploy setting: @msg', ['@msg' => $e->getMessage()]);
  }

  return FALSE;
}

/**
 * Implements hook_entity_insert().
 */
function zu_rest_api_entity_insert(EntityInterface $entity)
{
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'blogs') {

    $queue = \Drupal::service('queue')->get('zu_rest_api_blog_notification_queue');
    $blog_title = $entity->label();
    // $blog_url = $entity->toUrl('canonical', ['absolute' => TRUE])->toString();
    $blog_url = \Drupal\Core\Url::fromRoute('entity.node.canonical', ['node' => $entity->id()], ['absolute' => TRUE])->toString();


    $uids = \Drupal::entityQuery('user')
      ->condition('status', 1)
      ->condition('roles', 'blogs_subscriber')
      ->accessCheck(FALSE)
      ->execute();

    if (empty($uids)) {
      \Drupal::logger('zu_rest_api')->notice('No subscribers found for new blog "@title".', ['@title' => $blog_title]);
      return;
    }

    $users = \Drupal::entityTypeManager()->getStorage('user')->loadMultiple($uids);

    foreach ($users as $user) {
      if ($email = $user->getEmail()) {
        $queue->createItem([
          'email' => $email,
          'blog_title' => $blog_title,
          'blog_url' => $blog_url,
        ]);
      }
    }

    \Drupal::logger('zu_rest_api')->notice('Queued @count notifications for new blog "@title".', [
      '@count' => count($uids),
      '@title' => $blog_title,
    ]);
  }
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'page') {
    // Basic page JSON should only deploy from layout builder "Deploy Page".
    return;
  }
}

function zu_rest_api_cron()
{
  $queue = \Drupal::service('queue')->get('zu_rest_api_blog_notification_queue');
  $worker = \Drupal::service('plugin.manager.queue_worker')->createInstance('zu_rest_api_blog_notification_queue');

  while ($item = $queue->claimItem()) {
    try {
      $worker->processItem($item->data);
      $queue->deleteItem($item);
    } catch (\Throwable $e) {
      \Drupal::logger('zu_rest_api')->error('Blog queue error: @msg', ['@msg' => $e->getMessage()]);
      $queue->releaseItem($item);
    }
  }
}

