/**
 * Helper: Count unique uids subscribed for a given flag id.
 *
 * @param string $flag_id
 *   The flag machine name (ex: 'blog_subscribe').
 *
 * @return int
 *   Count of distinct uids (unique subscribers).
 */
function zu_count_total_flag_users(string $flag_id): int
{
  $connection = \Drupal::database();
  try {
    $query = $connection->select('flagging', 'f');
    $query->addExpression('COUNT(DISTINCT f.uid)', 'unique_subscribers');
    $query->condition('f.flag_id', $flag_id);
    $query->condition('f.entity_type', 'public_user');
    return (int) $query->execute()->fetchField();
  } catch (\Exception $e) {
    \Drupal::logger('zu_rest_api')->error('Failed counting unique users for flag @flag: @msg', [
      '@flag' => $flag_id,
      '@msg' => $e->getMessage(),
    ]);
    return 0;
  }
}

/**
 * Helper: Return a map of entity_id => count for a given flag id.
 *
 * For your setup entity_id stores taxonomy term id (TID) and entity_type is
 * 'public_user' (based on your screenshots). This returns how many flagging
 * rows exist for each entity_id.
 *
 * @param string $flag_id
 *   The flag machine name.
 *
 * @return int[]
 *   Associative array keyed by entity_id (string/int) with integer counts.
 */
function zu_count_flag_subscribers_by_term(string $flag_id): array
{
  $connection = \Drupal::database();
  $counts = [];

  try {
    $query = $connection->select('flagging', 'f');
    $query->fields('f', ['entity_id']);
    $query->condition('f.flag_id', $flag_id);
    $query->condition('f.entity_type', 'public_user');
    $results = $query->execute()->fetchCol();

    foreach ($results as $entity_id) {
      $key = (string) $entity_id;
      if (!isset($counts[$key])) {
        $counts[$key] = 0;
      }
      $counts[$key]++;
    }
  } catch (\Exception $e) {
    \Drupal::logger('zu_rest_api')->error('Failed building subscriber counts for flag @flag: @msg', [
      '@flag' => $flag_id,
      '@msg' => $e->getMessage(),
    ]);
  }

  return $counts;
}

/**
 * Implements hook_preprocess_views_view().
 *
 * Provides dashboard counts and chart data for blog_listing/news_api views.
 */
function zu_rest_api_preprocess_views_view(array &$variables)
{
  /** @var \Drupal\views\ViewExecutable $view */
  $view = $variables['view'];

  if ($view->id() == 'event_dashboard') {
    $variables['view']->element['#attached']['library'][] = 'zu_rest_api/admin_scripts';
  }

  if (
    $view->id() == 'blog_listing' || $view->current_display == 'blog_dashboard' ||
    $view->id() == 'news_api' || $view->current_display == 'news_dashboard' ||
    $view->id() == 'faculty' || $view->current_display == 'faculty_staff_dashboard'
  ) {

    $connection = \Drupal::database();
    $entity_type_manager = \Drupal::entityTypeManager();
    $storage = $entity_type_manager->getStorage('node');
    $current_lang = \Drupal::languageManager()->getCurrentLanguage()->getId();

    if ($view->id() == 'blog_listing' || $view->current_display == 'blog_dashboard') {
      $total = $storage->getQuery()
        ->condition('type', 'blogs')
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $published = $storage->getQuery()
        ->condition('type', 'blogs')
        ->condition('status', 1)
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $draft = $storage->getQuery()
        ->condition('type', 'blogs')
        ->condition('status', 0)
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $needs_review = 0;

      $subscribe_flag_id = 'blog_subscribe';
      $flagging_storage = $entity_type_manager->getStorage('flagging');

      $terms_to_check = $entity_type_manager->getStorage('taxonomy_term')->loadTree('blog_tags');
      $term_data_report = [];
      $term_subscriber_counts_legacy = [];

      $term_subscribers_map = zu_count_flag_subscribers_by_term($subscribe_flag_id);
      $total_subscribers = zu_count_total_flag_users($subscribe_flag_id);

      foreach ($terms_to_check as $term_object) {
        $tid = $term_object->tid;
        $term_name = $term_object->name;

        $node_count = (int) \Drupal::entityQuery('node')
          ->condition('type', 'blogs')
          ->condition('status', 1)
          ->condition('field_categories', $tid)
          ->condition('langcode', $current_lang)
          ->accessCheck(FALSE)
          ->count()
          ->execute();

        $subscriber_count = isset($term_subscribers_map[(string) $tid]) ? (int) $term_subscribers_map[(string) $tid] : 0;

        $term_data_report[] = [
          'tid' => $tid,
          'term_name' => $term_name,
          'node_count' => $node_count,
          'subscriber_count' => $subscriber_count,
        ];

        $term_subscriber_counts_legacy[$tid] = $subscriber_count;
      }

      $monthly_subscriptions = [];
      try {
        $results = $connection->select('flagging', 'f')
          ->fields('f', ['created'])
          ->condition('f.flag_id', $subscribe_flag_id)
          ->condition('f.entity_type', 'public_user')
          ->orderBy('created', 'DESC')
          ->execute()
          ->fetchAll();

        foreach ($results as $result) {
          $month_year = date('Y-m', $result->created);
          if (!isset($monthly_subscriptions[$month_year])) {
            $monthly_subscriptions[$month_year] = 0;
          }
          $monthly_subscriptions[$month_year]++;
        }
      } catch (\Exception $e) {
        \Drupal::logger('zu_rest_api')->error('Monthly subscription aggregation failed for blog_subscribe: @msg', [
          '@msg' => $e->getMessage(),
        ]);
      }

      ksort($monthly_subscriptions);
      $chart_labels = [];
      $chart_data = [];
      foreach ($monthly_subscriptions as $month_year => $count) {
        $timestamp = strtotime($month_year . '-01');
        if ($timestamp !== FALSE) {
          $chart_labels[] = date('M Y', $timestamp);
          $chart_data[] = $count;
        }
      }
      $monthly_chart_data = [
        'labels' => $chart_labels,
        'data' => $chart_data,
      ];

      $taxonomy_data = [];
      foreach ($term_data_report as $item) {
        $taxonomy_data[] = [
          'term_name' => ['#markup' => $item['term_name']],
          'term_count' => ['#markup' => $item['node_count']],
        ];
      }

      $account = \Drupal::currentUser();
      $variables['user_roles'] = $account->getRoles();

      $variables['total_blogs'] = $total;
      $variables['published_blogs'] = $published;
      $variables['draft_blogs'] = $draft;
      $variables['total_subscribers'] = $total_subscribers;
      $variables['term_data_report'] = $term_data_report;
      $variables['taxonomy_terms'] = $taxonomy_data;
      $variables['monthly_chart_data'] = $monthly_chart_data;

      $variables['#attached']['drupalSettings']['blogCalendar'] = [
        'dailyChartData' => $monthly_chart_data,
      ];
    }

    if ($view->id() == 'news_api' || $view->current_display == 'news_dashboard') {
      $total = $storage->getQuery()
        ->condition('type', 'news')
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $published = $storage->getQuery()
        ->condition('type', 'news')
        ->condition('status', 1)
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $draft = $storage->getQuery()
        ->condition('type', 'news')
        ->condition('status', 0)
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $subscribe_flag_id = 'news_subscribe';
      $flagging_storage = $entity_type_manager->getStorage('flagging');

      $terms_to_check = $entity_type_manager->getStorage('taxonomy_term')->loadTree('news_tags');
      $term_data_report = [];

      $term_subscribers_map = zu_count_flag_subscribers_by_term($subscribe_flag_id);
      $total_subscribers = zu_count_total_flag_users($subscribe_flag_id);

      foreach ($terms_to_check as $term_object) {
        $tid = $term_object->tid;
        $term_name = $term_object->name;

        $node_count = (int) \Drupal::entityQuery('node')
          ->condition('type', 'news')
          ->condition('status', 1)
          ->condition('field_tags', $tid)
          ->condition('langcode', $current_lang)
          ->accessCheck(FALSE)
          ->count()
          ->execute();

        $subscriber_count = isset($term_subscribers_map[(string) $tid]) ? (int) $term_subscribers_map[(string) $tid] : 0;

        $term_data_report[] = [
          'tid' => $tid,
          'term_name' => $term_name,
          'node_count' => $node_count,
          'subscriber_count' => $subscriber_count,
        ];
      }

      $monthly_subscriptions = [];
      try {
        $results = $connection->select('flagging', 'f')
          ->fields('f', ['created'])
          ->condition('f.flag_id', $subscribe_flag_id)
          ->condition('f.entity_type', 'public_user')
          ->orderBy('created', 'DESC')
          ->execute()
          ->fetchAll();

        foreach ($results as $result) {
          $month_year = date('Y-m', $result->created);
          if (!isset($monthly_subscriptions[$month_year])) {
            $monthly_subscriptions[$month_year] = 0;
          }
          $monthly_subscriptions[$month_year]++;
        }
      } catch (\Exception $e) {
        \Drupal::logger('zu_rest_api')->error('Monthly subscription aggregation failed for news_subscribe: @msg', [
          '@msg' => $e->getMessage(),
        ]);
      }

      ksort($monthly_subscriptions);
      $chart_labels = [];
      $chart_data = [];
      foreach ($monthly_subscriptions as $month_year => $count) {
        $timestamp = strtotime($month_year . '-01');
        if ($timestamp !== FALSE) {
          $chart_labels[] = date('M Y', $timestamp);
          $chart_data[] = $count;
        }
      }
      $monthly_chart_data = [
        'labels' => $chart_labels,
        'data' => $chart_data,
      ];

      $taxonomy_data = [];
      foreach ($term_data_report as $item) {
        $taxonomy_data[] = [
          'term_name' => ['#markup' => $item['term_name']],
          'term_count' => ['#markup' => $item['node_count']],
        ];
      }

      $account = \Drupal::currentUser();
      $variables['user_roles'] = $account->getRoles();

      $variables['total_news'] = $total;
      $variables['published_news'] = $published;
      $variables['draft_news'] = $draft;
      $variables['total_subscribers'] = $total_subscribers;
      $variables['term_data_report'] = $term_data_report;
      $variables['taxonomy_terms'] = $taxonomy_data;
      $variables['monthly_chart_data'] = $monthly_chart_data;

      $variables['#attached']['drupalSettings']['newsCalendar'] = [
        'dailyChartData' => $monthly_chart_data,
      ];
    }

    if ($view->id() == 'faculty' || $view->current_display == 'faculty_staff_dashboard') {
      $total = $storage->getQuery()
        ->condition('type', 'faculty_staff')
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $published = $storage->getQuery()
        ->condition('type', 'faculty_staff')
        ->condition('status', 1)
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $draft = $storage->getQuery()
        ->condition('type', 'faculty_staff')
        ->condition('status', 0)
        ->condition('langcode', $current_lang)
        ->accessCheck(FALSE)
        ->count()
        ->execute();

      $subscribe_flag_id = 'newsletter_subscribe';
      $flagging_storage = $entity_type_manager->getStorage('flagging');

      $terms_to_check = $entity_type_manager->getStorage('taxonomy_term')->loadTree('area_of_expertise');
      $term_data_report = [];

      $term_subscribers_map = zu_count_flag_subscribers_by_term($subscribe_flag_id);
      $total_subscribers = zu_count_total_flag_users($subscribe_flag_id);

      foreach ($terms_to_check as $term_object) {
        $tid = $term_object->tid;
        $term_name = $term_object->name;

        $node_count = (int) \Drupal::entityQuery('node')
          ->condition('type', 'faculty_staff')
          ->condition('status', 1)
          ->condition('field_area_of_expertise', $tid)
          ->condition('langcode', $current_lang)
          ->accessCheck(FALSE)
          ->count()
          ->execute();

        $subscriber_count = isset($term_subscribers_map[(string) $tid]) ? (int) $term_subscribers_map[(string) $tid] : 0;

        $term_data_report[] = [
          'tid' => $tid,
          'term_name' => $term_name,
          'node_count' => $node_count,
          'subscriber_count' => $subscriber_count,
        ];
      }

      $taxonomy_data = [];
      foreach ($term_data_report as $item) {
        $taxonomy_data[] = [
          'term_name' => ['#markup' => $item['term_name']],
          'term_count' => ['#markup' => $item['node_count']],
        ];
      }

      $account = \Drupal::currentUser();
      $variables['user_roles'] = $account->getRoles();
      $variables['total_faculty'] = $total;
      $variables['published_faculty'] = $published;
      $variables['draft_faculty'] = $draft;
      $variables['total_subscribers'] = $total_subscribers;
      $variables['term_data_report'] = $term_data_report;
      $variables['taxonomy_terms'] = $taxonomy_data;
    }
  }
}

/**
 * Implements hook_preprocess_comment().
 */
function zu_rest_api_preprocess_comment(array &$variables)
{
  /** @var \Drupal\comment\Entity\Comment $comment */
  $comment = $variables['comment'];

  $uid = $comment->getOwnerId();
  $owner = $comment->getOwner();
  $entityTypeManager = \Drupal::entityTypeManager();

  if ($owner && $owner->id() && $owner->isAuthenticated()) {
    $variables['author'] = $owner->getAccountName();
    return;
  }

  $publicUser = $entityTypeManager->getStorage('public_user')->load($uid);

  if ($publicUser) {
    $authorName = $publicUser->get('name')->value;
    $variables['author'] = $authorName;
    $variables['submitted'] = t('Submitted by @name', ['@name' => $authorName]);
  } else {
    $variables['author'] = 'Anonymous';
  }
}

/**
 * Implements hook_entity_update().
 */
function zu_rest_api_entity_update(\Drupal\Core\Entity\EntityInterface $entity)
{
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'page') {

    $original = $entity->original;
    if ($original && $original->isPublished() && !$entity->isPublished()) {
      return;
    }
    // Basic page JSON should only deploy from layout builder "Deploy Page".
    return;
  }

  // Keep Event/Email Template translation state + publish status aligned.
  if ($entity->getEntityTypeId() === 'node' && in_array($entity->bundle(), ['event', 'email_template'])) {
    _zu_rest_api_sync_moderation_and_status($entity);
  }
}

/**
 * Normalizes moderation state + status for all translations on a node.
 *
 * This avoids EN/AR drift where moderation is updated on one translation while
 * publication status remains stale on another translation.
 */
function _zu_rest_api_sync_moderation_and_status(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || !$entity->id()) {
    return;
  }
  if (!$entity->hasField('moderation_state') || $entity->get('moderation_state')->isEmpty()) {
    return;
  }

  static $running = [];
  $nid = (int) $entity->id();
  if (isset($running[$nid])) {
    return;
  }
  $running[$nid] = TRUE;

  try {
    $target_state = (string) $entity->get('moderation_state')->value;
    $target_status = ($target_state === 'published') ? 1 : 0;
    $revision_id = (int) $entity->getRevisionId();
    $database = \Drupal::database();

    // One authoritative moderation row per translation in current data table.
    $database->query(
      "DELETE cms_old FROM {content_moderation_state_field_data} cms_old
       INNER JOIN {content_moderation_state_field_data} cms_new
         ON cms_old.content_entity_id = cms_new.content_entity_id
        AND cms_old.langcode = cms_new.langcode
        AND cms_old.content_entity_type_id = cms_new.content_entity_type_id
        AND cms_old.id < cms_new.id
       WHERE cms_old.content_entity_type_id = 'node' AND cms_old.content_entity_id = :nid",
      [':nid' => $nid]
    );

    // Keep moderation state identical across translations for this node.
    $database->update('content_moderation_state_field_data')
      ->fields(['moderation_state' => $target_state])
      ->condition('content_entity_type_id', 'node')
      ->condition('content_entity_id', $nid)
      ->execute();

    // Keep publish status aligned with moderation state in canonical table.
    $database->update('node_field_data')
      ->fields(['status' => $target_status])
      ->condition('nid', $nid)
      ->execute();

    if ($revision_id > 0) {
      // Mirror state/status on the current revision rows as well.
      $database->update('content_moderation_state_field_revision')
        ->fields(['moderation_state' => $target_state])
        ->condition('content_entity_type_id', 'node')
        ->condition('content_entity_id', $nid)
        ->condition('content_entity_revision_id', $revision_id)
        ->execute();

      $database->update('node_field_revision')
        ->fields(['status' => $target_status])
        ->condition('nid', $nid)
        ->condition('vid', $revision_id)
        ->execute();
    }
  } catch (\Exception $e) {
    \Drupal::logger('zu_rest_api')->error('Failed syncing moderation/status for node @nid: @msg', [
      '@nid' => $entity->id(),
      '@msg' => $e->getMessage(),
    ]);
  } finally {
    unset($running[$nid]);
  }
}

/**
 * Implements hook_entity_predelete().
 */
function zu_rest_api_entity_predelete(\Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'page') {
    $aliases = _zu_rest_api_collect_aliases($entity);
    \Drupal::request()->attributes->set('zu_deleted_aliases_' . $entity->id(), $aliases);
  }
}

/**
 * Implements hook_entity_delete().
 */
function zu_rest_api_entity_delete(\Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'page') {
    if (_zu_rest_api_has_layoutbuilder_data($entity->id())) {
      return;
    }
    $aliases = \Drupal::request()->attributes->get('zu_deleted_aliases_' . $entity->id(), []);
    \Drupal::service('zu_rest_api.deploy_page')->deletePage($entity, is_array($aliases) ? $aliases : []);
  }
}

/**
 * Skip basic page deploy for the current request.
 */
function _zu_rest_api_skip_basic_page_deploy(): bool {
  return (bool) \Drupal::request()->attributes->get('zu_skip_basic_page_deploy', false);
}

/**
 * Check if a node has layout builder data stored.
 */
function _zu_rest_api_has_layoutbuilder_data(int $nid): bool {
  static $table_exists = null;
  static $cache = [];

  if (isset($cache[$nid])) {
    return $cache[$nid];
  }

  try {
    $connection = \Drupal::database();
    if ($table_exists === null) {
      $table_exists = $connection->schema()->tableExists('drupal_layoutbuilder_data');
    }
    if (!$table_exists) {
      $cache[$nid] = FALSE;
      return FALSE;
    }
    $result = $connection->query(
      "SELECT 1 FROM drupal_layoutbuilder_data WHERE uid = :nid LIMIT 1",
      [':nid' => $nid]
    )->fetchField();
    $cache[$nid] = (bool) $result;
    return $cache[$nid];
  }
  catch (\Exception $e) {
    \Drupal::logger('zu_rest_api')->error('Error checking drupal_layoutbuilder_data: @msg', ['@msg' => $e->getMessage()]);
    $cache[$nid] = FALSE;
    return FALSE;
  }
}

/**
 * Collect aliases by language for a node.
 */
function _zu_rest_api_collect_aliases(\Drupal\node\NodeInterface $node): array {
  $aliases = [];
  $path_alias_manager = \Drupal::service('path_alias.manager');
  $langcodes = array_keys($node->getTranslationLanguages());
  if (empty($langcodes)) {
    $langcodes = [$node->language()->getId()];
  }

  foreach ($langcodes as $langcode) {
    $node_lang = $node->hasTranslation($langcode) ? $node->getTranslation($langcode) : $node;
    $alias = '';
    if ($node_lang->hasField('path') && !$node_lang->get('path')->isEmpty()) {
      $alias = (string) ($node_lang->get('path')->alias ?? '');
    }
    if (empty($alias)) {
      $alias = $path_alias_manager->getAliasByPath('/node/' . $node->id(), $langcode);
    }
    if (!empty($alias) && $alias !== '/node/' . $node->id()) {
      $aliases[$langcode] = $alias;
    }
  }

  return $aliases;
}
function zu_rest_api_preprocess_views_view_field(&$variables) {
  $view = $variables['view'];
  $field_id = $variables['field']->options['id'];
  $account = \Drupal::currentUser();

  if ($variables['view']->id() !== 'event_dashboard') {
    return;
  }

  $variables['view']->element['#attached']['library'][] = 'core/drupal.ajax';

  if ($field_id === 'nothing') {
    if (!$account->hasPermission('manage event dashboard')) {
      return;
    }
    $nid = $variables['row']->_entity->id();

    $count = (int) \Drupal::database()->select('flagging', 'f')
      ->condition('flag_id', 'bookmark')
      ->condition('entity_id', $nid)
      ->countQuery()
      ->execute()
      ->fetchField();

    if ($count > 0) {
      $url = \Drupal\Core\Url::fromRoute('event_calendar.event_bookmarks', ['nid' => $nid], [
        'attributes' => [
          'target' => '_blank',
        ],
      ]);

      $variables['output'] = [
        '#type' => 'link',
        '#title' => $count,
        '#url' => $url,
        '#cache' => [
          'max-age' => 0,
          'tags' => ['flagging_list', "node:$nid"],
        ],
      ];
    } else {
      $variables['output'] = [
        '#markup' => '0',
        '#cache' => [
          'max-age' => 0,
          'tags' => ['flagging_list', "node:$nid"],
        ],
      ];
    }

    return;
  }

  if ($field_id === 'nothing_2') {
    if (!$account->hasPermission('manage event dashboard')) {
      return;
    }
    $node = $variables['row']->_entity;
    $nid = $node->id();

    // Load latest revision to determine actual state for the toggle button.
    $node_storage = \Drupal::entityTypeManager()->getStorage('node');
    $latest_id = $node_storage->getLatestRevisionId($nid);
    $latest = $latest_id ? $node_storage->loadRevision($latest_id) : $node;

    $current = $latest->get('moderation_state')->value;

    if ($current === 'published') {
      $label = 'Unpublish';
      $class = 'toggle-Unpublish';
    } else {
      $label = 'Publish';
      $class = 'toggle-Publish';
    }

    $url = \Drupal\Core\Url::fromUserInput("/toggle-publish/$nid", [
      'attributes' => [
        'class' => ['use-ajax', $class],
        'id' => "toggle-publish-$nid",
      ],
      'query' => ['t' => time()],
    ]);

    $variables['output'] = [
      '#markup' =>
      "<span id='toggle-wrapper-$nid'>" .
        \Drupal\Core\Link::fromTextAndUrl($label, $url)->toString() .
        "</span>",
      '#allowed_tags' => ['span', 'a'],
    ];
    return;
  }

  if ($field_id === 'nothing_3') {
    if (!$account->hasPermission('manage event dashboard')) {
      return;
    }
    $node = $variables['row']->_entity;
    $field = 'field_select_webform';

    if (!$node->hasField($field) || $node->get($field)->isEmpty()) {
      $variables['output'] = ['#markup' => '0'];
      return;
    }

    $webform_id = $node->get($field)->target_id;

    $count = \Drupal::entityTypeManager()
      ->getStorage('webform_submission')
      ->getQuery()
      ->condition('webform_id', $webform_id)
      ->accessCheck(FALSE)
      ->count()
      ->execute();

    $url = \Drupal\Core\Url::fromRoute(
      'entity.webform.results_submissions',
      ['webform' => $webform_id]
    );

    $variables['output'] = [
      '#markup' => "<a href='{$url->toString()}' target='_blank'>$count</a>",
      '#allowed_tags' => ['a'],
    ];
    return;
  }

  if ($field_id === 'moderation_state') {
    $node = $variables['row']->_entity;
    $nid = $node->id();

    // load the latest revision to ensure we show the most recent state.
    $node_storage = \Drupal::entityTypeManager()->getStorage('node');
    $moderation_info = \Drupal::service('content_moderation.moderation_information');
    $latest_revision_id = $node_storage->getLatestRevisionId($nid);
    $latest_revision = $latest_revision_id ? $node_storage->loadRevision($latest_revision_id) : NULL;
    
    $state_label = '';
    if ($latest_revision) {
      $state = $latest_revision->get('moderation_state')->value;
      $workflow = $moderation_info->getWorkflowForEntity($latest_revision);
      if ($workflow) {
        $state_object = $workflow->getTypePlugin()->getState($state);
        $state_label = $state_object->label();
      }
    }

    if ($state_label) {
      $variables['output'] = [
        '#markup' => "<span id='moderation-state-$nid'>$state_label</span>",
        '#allowed_tags' => ['span'],
      ];
    } else {
      $original_output = (string) $variables['output']; 
      $variables['output'] = [
        '#markup' => "<span id='moderation-state-$nid'>$original_output</span>",
        '#allowed_tags' => ['span'],
      ];
    }
  }
}

/**
 * Implements hook_preprocess_views_view_table().
 */
function zu_rest_api_preprocess_views_view_table(&$variables) {
  $view = $variables['view'];
  if ($view->id() !== 'event_dashboard') {
    return;
  }

  foreach ($variables['rows'] as $index => $row) {
    if (isset($row['columns']['moderation_state'])) {
      $node = $view->result[$index]->_entity;
      if ($node) {
        $nid = $node->id();
        $original_content = '';
        if (isset($variables['rows'][$index]['columns']['moderation_state']['content'][0]['field_output']['#markup'])) {
             $original_content = $variables['rows'][$index]['columns']['moderation_state']['content'][0]['field_output']['#markup'];
        } elseif (isset($variables['rows'][$index]['columns']['moderation_state']['content'][0]['field_output'])) {
             $original_content = (string) $variables['rows'][$index]['columns']['moderation_state']['content'][0]['field_output'];
        }

        $variables['rows'][$index]['columns']['moderation_state']['content'][0]['field_output'] = [
          '#markup' => "<span id='moderation-state-$nid'>$original_content</span>",
          '#allowed_tags' => ['span'],
        ];
      }
    }
  }
}

/**
 * Custom validation handler for news date fields.
 */
function zu_rest_api_news_date_validate($form, FormStateInterface $form_state) {
  $now = new DrupalDateTime('now', 'UTC');
  $now_ts = $now->getTimestamp() - 60;

  $expiry_date_value = $form_state->getValue('field_expiry_date');
  $expiry_ts = NULL;
  if (!empty($expiry_date_value[0]['value'])) {
    $expiry_val = $expiry_date_value[0]['value'];
    $expiry_date = zu_rest_api_parse_datetime_form_value($expiry_val);
    if ($expiry_date === FALSE) {
      $form_state->setErrorByName('field_expiry_date', t('Please enter both date and time for the expiry date.'));
    }
    elseif ($expiry_date instanceof DrupalDateTime) {
      $expiry_ts = $expiry_date->getTimestamp();
      if ($expiry_ts < $now_ts) {
        $form_state->setErrorByName('field_expiry_date', t('The expiry date and time cannot be in the past.'));
      }
    }
  }

  $created_value = $form_state->getValue('created');
  $created_val = NULL;
  if (is_array($created_value) && isset($created_value[0]['value'])) {
    $created_val = $created_value[0]['value'];
  }
  elseif (!empty($created_value)) {
    $created_val = $created_value;
  }

  $created_ts = zu_rest_api_datetime_form_value_timestamp($created_val);
  if ($created_ts) {
    $node = $form_state->getFormObject()->getEntity();
    $is_new = $node->isNew();
    $original_created = !$is_new ? (int) $node->getCreatedTime() : NULL;

    if ($is_new || ($original_created !== NULL && $created_ts !== $original_created)) {
      if ($created_ts < $now_ts) {
        $form_state->setErrorByName('created', t('The authoring date (creation date) cannot be in the past.'));
      }
    }

    if ($expiry_ts && $expiry_ts < $created_ts) {
      $form_state->setErrorByName('field_expiry_date', t('The expiry date cannot be earlier than the authored date.'));
    }
  }
}

/**
 * Parses a datetime form element or field widget value.
 *
 * @return \Drupal\Core\Datetime\DrupalDateTime|null|false
 *   A date object, NULL when empty/invalid, FALSE when date is set without time.
 */
function zu_rest_api_parse_datetime_form_value(mixed $raw): DrupalDateTime|null|false {
  if ($raw instanceof DrupalDateTime) {
    return $raw->hasErrors() ? NULL : $raw;
  }
  if (is_string($raw) && $raw !== '') {
    try {
      $date = new DrupalDateTime($raw, 'UTC');
      return $date->hasErrors() ? NULL : $date;
    }
    catch (\Exception) {
      return NULL;
    }
  }
  if (!is_array($raw)) {
    return NULL;
  }

  if (!empty($raw['object']) && $raw['object'] instanceof DrupalDateTime && !$raw['object']->hasErrors()) {
    return $raw['object'];
  }

  $date_part = trim((string) ($raw['date'] ?? ''));
  $time_part = trim((string) ($raw['time'] ?? ''));
  if ($date_part === '') {
    return NULL;
  }
  if ($time_part === '') {
    return FALSE;
  }
  if (strlen($time_part) === 5) {
    $time_part .= ':00';
  }

  $timezone = date_default_timezone_get();
  try {
    $date = DrupalDateTime::createFromFormat('Y-m-d H:i:s', $date_part . ' ' . $time_part, $timezone);
    if ($date instanceof DrupalDateTime && !$date->hasErrors()) {
      return $date;
    }
  }
  catch (\Exception) {
    // Fall through.
  }

  try {
    $date = new DrupalDateTime($date_part . 'T' . $time_part, $timezone);
    return $date->hasErrors() ? NULL : $date;
  }
  catch (\Exception) {
    return NULL;
  }
}

/**
 * Returns a Unix timestamp from assorted datetime form values.
 */
function zu_rest_api_datetime_form_value_timestamp(mixed $raw): ?int {
  if (is_numeric($raw)) {
    return (int) $raw;
  }
  $date = zu_rest_api_parse_datetime_form_value($raw);
  if ($date instanceof DrupalDateTime) {
    return $date->getTimestamp();
  }
  if (is_string($raw) && $raw !== '') {
    $ts = strtotime($raw);
    return $ts !== FALSE ? $ts : NULL;
  }
  return NULL;
}

/**
 * Implements hook_form_FORM_ID_alter() for auto_node_translate_form.
 */
function zu_rest_api_form_auto_node_translate_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  $form['save']['#submit'][] = 'zu_rest_api_auto_node_translate_redirect';
}

/**
 * Custom submit handler to redirect to the correct translation language.
 */
function zu_rest_api_auto_node_translate_redirect($form, FormStateInterface $form_state)
{
  $translations = $form_state->getValue('translate');
  $selected_lang = NULL;
  foreach ($translations as $langcode => $val) {
    if ($val) {
      $selected_lang = $langcode;
      break;
    }
  }

  if ($selected_lang) {
    $node = \Drupal::routeMatch()->getParameter('node');
    if ($node) {
      $options = [
        'language' => \Drupal::languageManager()->getLanguage($selected_lang),
      ];
      $form_state->setRedirect('entity.node.canonical', ['node' => $node->id()], $options);
    }
  }
}

/**
 * Implements hook_node_presave().
 */
function zu_rest_api_node_presave(NodeInterface $node)
{
  if ($node->bundle() === 'news') {
    if ($node->hasField('path')) {
      $node->path->pathauto = 1;
    }
  }

  if (in_array($node->bundle(), ['event', 'email_template'])) {
    $new_state = $node->hasField('moderation_state') ? $node->get('moderation_state')->value : NULL;
    $original = $node->original;

    if ($original) {
      $old_state = $original->get('moderation_state')->value ?? NULL;

      $current_user = \Drupal::currentUser();
      $roles = $current_user->getRoles();
      $is_admin = in_array('administrator', $roles) || in_array('super_admin', $roles);
      
      if (!$is_admin && $old_state === 'published' && $new_state === 'published') {
        $excluded_fields = [
          'field_view_count',
          'field_campaign',
          'field_template_screenshot_data',
          'changed'
        ];

        foreach ($node->getFields() as $name => $field) {
          if (in_array($name, $excluded_fields)) {
            continue;
          }

          if ($name !== 'title' && $name !== 'body' && strpos($name, 'field_') !== 0) {
            continue;
          }

          if ($node->get($name)->getString() !== $node->original->get($name)->getString()) {
            $node->set('moderation_state', 'needs_review');
            $new_state = 'needs_review';
            break;
          }
        }
      }
    }

    if ($new_state) {
      $is_published = ($new_state === 'published');
      foreach ($node->getTranslationLanguages() as $langcode => $language) {
        if (!$node->hasTranslation($langcode)) {
          continue;
        }
        $translation = $node->getTranslation($langcode);
        $translation->set('moderation_state', $new_state);
        $translation->set('status', $is_published ? 1 : 0);
        $translation->setPublished($is_published);
      }

      // Keep workflow changes on the default revision for dashboard consistency.
      $node->isDefaultRevision(TRUE);
    }
  }
}



/**
 * Implements hook_entity_translation_insert().
 */
function zu_rest_api_entity_translation_insert(\Drupal\Core\Entity\EntityInterface $translation)
{
  if ($translation instanceof \Drupal\node\NodeInterface) {
    \Drupal::logger('zu_debug')->info('Translation Insert: node @id, lang: @lang', [
      '@id' => $translation->id(),
      '@lang' => $translation->language()->getId(),
    ]);
    if ($translation->hasField('path')) {
      $translation->path->pathauto = 1;
      \Drupal::service('pathauto.generator')->updateEntityAlias($translation, 'insert');
    }
  }
}

/**
 * Implements hook_node_validate().
 */
function zu_rest_api_node_validate(\Drupal\node\NodeInterface $node, $form, \Drupal\Core\Form\FormStateInterface $form_state)
{
  if ($node->getType() === 'news') {
    $authored_on = $node->getCreatedTime();
    $expiry_date_item = $node->get('field_expiry_date')->first();

    if ($expiry_date_item) {
      $expiry_date_value = $expiry_date_item->value;
      if ($expiry_date_value) {
        $expiry_timestamp = strtotime($expiry_date_value);
        if ($expiry_timestamp < $authored_on) {
          $form_state->setErrorByName('field_expiry_date', t('The expiry date cannot be earlier than the authored date.'));
        }
      }
    }
  }
}

/**
 * Provides allowed values for the social media icons field.
 *
 * @param \Drupal\Core\Field\FieldStorageDefinitionInterface $definition
 *   The field storage definition.
 * @param \Drupal\Core\Entity\FieldableEntityInterface|null $entity
 *   The entity being edited.
 * @param bool &$cacheable
 *   Whether the results are cacheable.
 *
 * @return array
 *   An array of allowed values.
 */
function zu_rest_api_social_media_allowed_values($definition, $entity = NULL, &$cacheable = TRUE) {
  $config = \Drupal::config('zu_rest_api.social_media');
  $platforms = $config->get('platforms') ?: [];
  $options = [];
  foreach ($platforms as $id => $data) {
    if (!empty($data['label'])) {
      $options[$id] = $data['label'];
    }
    else {
      $options[$id] = $id;
    }
  }
  return $options;
}
