<?php
/**
 * Implements hook_mail().
 */
function zu_public_user_mail($key, &$message, $params) {

  switch ($key) {
    case 'email_verification':
      $message['subject'] = $params['subject'] ?? 'Verify your Zayed University account';
      $body = '<p>Hello ' . htmlspecialchars($params['name'] ?? '', ENT_QUOTES) . ',</p>'
        . '<p>Please verify your email address by clicking the link below:</p>'
        . '<p><a href="' . htmlspecialchars($params['verify_url'] ?? '', ENT_QUOTES) . '">Verify my email</a></p>'
        . '<p>This link expires in 24 hours.</p>'
        . '<p>If you did not create this account, you can safely ignore this email.</p>';
      $message['body']                      = [strip_tags($body)];
      $message['params']['body']            = $body;
      $message['headers']['Content-Type']   = 'text/html; charset=UTF-8';
      break;

    case 'reset_password_otp':
      $message['subject'] = $params['subject'];
      $build = [
        '#theme' => 'reset_password_otp',
        '#name' => $params['name'] ?? '',
        '#token' => $params['token'] ?? '',
      ];
      $html = \Drupal::service('renderer')->renderPlain($build);
      //\Drupal::logger('zu_public_user')->notice("Rendered OTP Email:<br><pre>@b</pre>", ['@b' => $html]);
      $text = strip_tags($html);
      $message['params']['body'] = $html;
      $message['body'] = [$text];
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

      break;
  }
}

/**
 * Implements hook_theme().
 */
function zu_public_user_theme($existing, $type, $theme, $path) {
  return [
    'reset_password_otp' => [
      'template' => 'reset-password-otp',
      'variables' => [
        'name' => NULL,
        'token' => NULL,
      ],
    ],
  ];
}
